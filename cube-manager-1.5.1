/**
 * Label leggibile per lo stato richiesta.
 */
function cube_manager_request_status_label($status) {
    $labels = array(
        'draft' => 'Bozza',
        'pending_approval' => 'In attesa',
        'approved' => 'Approvata',
        'published' => 'Pubblicata',
        'rejected' => 'Rifiutata',
    );

    return isset($labels[$status]) ? $labels[$status] : $status;
}

/**
 * Classe CSS admin per lo stato richiesta.
 */
function cube_manager_request_status_class($status) {
    if ($status === 'pending_approval') {
        return 'notice-warning';
    }

    if ($status === 'approved' || $status === 'published') {
        return 'notice-success';
    }

    if ($status === 'rejected') {
        return 'notice-error';
    }

    return 'notice-info';
}


/**
 * Normalizza il testo delle istruzioni base.
 * Puoi incollare solo il contenuto delle istruzioni oppure un blocco Python tipo:
 * INSTRUCTIONS = """ ... """
 * In quel caso salva solo il contenuto interno, non il codice Python.
 */
function cube_manager_extract_instructions_text($raw_text) {
    $raw_text = trim((string) $raw_text);

    if ($raw_text === '') {
        return '';
    }

    if (preg_match('/INSTRUCTIONS\s*=\s*("""|\'\'\')([\s\S]*?)\1/', $raw_text, $matches)) {
        return trim((string) $matches[2]);
    }

    return $raw_text;
}

/**
 * Recupera l'ultima bozza/istruzione generata per la stessa struttura.
 * Serve a far capire all'AI se deve integrare modifiche su una versione precedente.
 */
function cube_manager_instruction_looks_complete($candidate, $base_instructions = '') {
    $candidate = trim((string) $candidate);
    $base_instructions = trim((string) $base_instructions);

    if ($candidate === '') {
        return false;
    }

    if ($base_instructions !== '') {
        $candidate_length = strlen($candidate);
        $base_length = strlen($base_instructions);

        // Se la nuova istruzione è molto più corta della base, quasi certamente
        // è un riassunto o una ricostruzione sbagliata, non una modifica chirurgica.
        if ($base_length > 2000 && $candidate_length < ($base_length * 0.70)) {
            return false;
        }

        $required_markers = array(
            'IDENTITY',
            'TONE OF VOICE',
            'WI-FI',
            'PROBLEM HANDLING',
            'EMERGENCIES',
            'MISSING INFORMATION',
        );

        foreach ($required_markers as $marker) {
            if (stripos($base_instructions, $marker) !== false && stripos($candidate, $marker) === false) {
                return false;
            }
        }
    }

    return true;
}

/**
 * Recupera le istruzioni complete da usare come base di modifica.
 * Logica corretta:
 * - se esiste una versione pubblicata/approvata completa, usa quella;
 * - se l'ultima versione pubblicata è sospetta o troppo corta, torna alle istruzioni base;
 * - se non esiste nulla, usa le istruzioni base della struttura.
 */
function cube_manager_get_latest_generated_instructions($structure_id, $exclude_request_id = 0) {
    global $wpdb;

    $versions_table = $wpdb->prefix . 'cube_define_versions';
    $structure = cube_manager_get_structure((int) $structure_id);
    $base_instructions = ($structure && !empty($structure->base_instructions))
        ? (string) $structure->base_instructions
        : '';

    $query_params = array((int) $structure_id);
    $exclude_sql = '';

    if ((int) $exclude_request_id > 0) {
        $exclude_sql = 'AND id != %d';
        $query_params[] = (int) $exclude_request_id;
    }

    $latest_rows = $wpdb->get_results(
        $wpdb->prepare(
            "SELECT generated_instructions
             FROM $versions_table
             WHERE structure_id = %d
             $exclude_sql
             AND generated_instructions IS NOT NULL
             AND generated_instructions != ''
             AND status IN ('approved', 'published')
             ORDER BY version_number DESC, id DESC
             LIMIT 5",
            $query_params
        )
    );

    if (!empty($latest_rows)) {
        foreach ($latest_rows as $row) {
            $candidate = isset($row->generated_instructions) ? (string) $row->generated_instructions : '';

            if (cube_manager_instruction_looks_complete($candidate, $base_instructions)) {
                return $candidate;
            }
        }
    }

    return $base_instructions;
}

/**
 * Estrae le sezioni numerate del blocco INSTRUCTIONS.
 * Serve per dare a OpenAI un indice chiaro delle sezioni disponibili e per ricostruire
 * sempre il prompt completo finale sostituendo solo le sezioni interessate.
 */
function cube_manager_extract_instruction_sections($instructions) {
    $instructions = (string) $instructions;
    $sections = array();

    $pattern = '/(^##\s*(\d+)\.\s+[^\r\n]*[\s\S]*?)(?=\n---\s*\R\R##\s*\d+\.\s+|\z)/m';

    if (preg_match_all($pattern, $instructions, $matches, PREG_SET_ORDER)) {
        foreach ($matches as $match) {
            $section_text = trim((string) $match[1]);
            $section_number = trim((string) $match[2]);
            $heading = '';

            if (preg_match('/^##\s*' . preg_quote($section_number, '/') . '\.\s+([^\r\n]+)/m', $section_text, $heading_match)) {
                $heading = trim((string) $heading_match[1]);
            }

            $sections[$section_number] = array(
                'number' => $section_number,
                'heading' => $heading,
                'text' => $section_text,
            );
        }
    }

    return $sections;
}

/**
 * Costruisce un indice compatto delle sezioni da inviare a OpenAI.
 */
function cube_manager_build_sections_index_for_ai($instructions) {
    $sections = cube_manager_extract_instruction_sections($instructions);
    $lines = array();

    foreach ($sections as $section) {
        $lines[] = '## ' . $section['number'] . '. ' . $section['heading'];
    }

    return implode("\n", $lines);
}

/**
 * Costruisce il prompt per OpenAI come editor intelligente per sezioni.
 * OpenAI deve analizzare semanticamente tutta la richiesta, individuare tutte le sezioni
 * direttamente o indirettamente coinvolte e restituire solo quelle sezioni complete riscritte.
 * Il plugin ricostruirà poi il prompt completo finale dal punto 1 al punto finale.
 */
function cube_manager_build_instructions_patch_prompt($request, $current_instructions = '', $retry_context = '') {
    $structure_name = isset($request->structure_name) ? (string) $request->structure_name : '';
    $city = isset($request->city) ? (string) $request->city : '';
    $uploaded_text = isset($request->uploaded_text) ? (string) $request->uploaded_text : '';
    $current_instructions = trim((string) $current_instructions);
    $sections_index = cube_manager_build_sections_index_for_ai($current_instructions);

    $prompt  = "You are an expert structured prompt editor for a CUBE voice assistant used inside a hospitality structure.\n";
    $prompt .= "Your job is to perform an intelligent consistency update of an existing operational prompt.\n";
    $prompt .= "You must think like a senior editor, QA reviewer, hospitality operations manager, and consistency checker.\n";
    $prompt .= "The customer may describe a change informally. You must infer every directly and indirectly affected section.\n\n";

    $prompt .= "STRUCTURE CONTEXT:\n";
    $prompt .= "Structure name: " . $structure_name . "\n";
    $prompt .= "City: " . $city . "\n\n";

    $prompt .= "SECTION INDEX:\n";
    $prompt .= $sections_index . "\n\n";

    $prompt .= "CURRENT COMPLETE INSTRUCTIONS — ABSOLUTE SOURCE OF TRUTH:\n";
    $prompt .= "These are the current complete instructions. The final instructions must keep the same full structure.\n";
    $prompt .= "The PHP system will rebuild the final complete instructions by replacing only the complete sections you return.\n\n";
    $prompt .= $current_instructions . "\n\n";

    $prompt .= "CUSTOMER UPDATE REQUEST:\n";
    $prompt .= $uploaded_text . "\n\n";

    if (trim((string) $retry_context) !== '') {
        $prompt .= "REPAIR CONTEXT FROM PREVIOUS FAILED ATTEMPT:\n";
        $prompt .= (string) $retry_context . "\n\n";
    }

    $prompt .= "CORE TASK:\n";
    $prompt .= "1. Understand whether the customer wants to ADD, MODIFY, REPLACE, REMOVE, or CLARIFY information.\n";
    $prompt .= "2. If a value is modified or replaced, identify the old value or old rule already present in the instructions, even if the customer does not explicitly name it.\n";
    $prompt .= "3. Search all sections literally and semantically for every occurrence, example, translation, explanation, spelling, pronunciation, summary, anti-error rule, recommended answer, and derived wording connected to that value.\n";
    $prompt .= "4. Rewrite every affected section completely from heading to end.\n";
    $prompt .= "5. Do not return unchanged sections. Do not return the full prompt.\n";
    $prompt .= "6. The PHP system will merge your returned sections back into the full prompt, so every returned section must be complete and ready to replace the old section.\n\n";

    $prompt .= "INTELLIGENT CONSISTENCY RULES — CRITICAL:\n";
    $prompt .= "- If a Wi-Fi password changes, update the main password, every sample answer, every multilingual sample answer, every repetition/spelling instruction, every punctuation note, every final-character warning, and every place where the old password appears or is described indirectly.\n";
    $prompt .= "- If the new Wi-Fi password must be spelled, recompute the spelling character by character from the new password. Never keep the spelling of the old password.\n";
    $prompt .= "- If the old password ended with one punctuation mark but the new password ends with another, update every sentence that describes the final character. Example: do not keep 'final exclamation mark' if the new password ends with '$'; rewrite it as 'final dollar sign' / 'simbolo del dollaro finale' where appropriate.\n";
    $prompt .= "- If a returned Wi-Fi section contains a new password, every dependent sentence in that section must be true for that exact password: examples, spelling, translations, punctuation warnings, and 'never forget' notes.\n";
    $prompt .= "- If a contact changes, update every direct contact line, WhatsApp reference, assistance routing sentence, example answer, and problem-handling section that uses that contact.\n";
    $prompt .= "- If a place/attraction is added or modified, update the main visit/attractions section and all suggestion/personalized-experience sections where a guest would expect that recommendation to appear.\n";
    $prompt .= "- If a restaurant/food service changes, update restaurant, in-room dining, food experience, breakfast/lunch/dinner, voucher, and recommendation sections where relevant.\n";
    $prompt .= "- If a coupon, website, address, opening rule, internal code word, device name, host name, or service detail changes, update every direct and indirect reference to keep the whole prompt coherent.\n";
    $prompt .= "- If an internal cleaning code word changes, update the entire internal code word section and all examples. Only the current exact code word or exact phrase may activate the procedure.\n";
    $prompt .= "- If the customer asks to add a new item, integrate it into every relevant existing section rather than creating isolated disconnected text.\n";
    $prompt .= "- If the customer asks to modify existing information, do not simply add the new information: replace or rewrite the existing old information wherever it appears.\n\n";

    $prompt .= "PRESERVATION RULES:\n";
    $prompt .= "- Preserve original numbering and headings unless the customer explicitly asks to change them.\n";
    $prompt .= "- Preserve all unrelated sections exactly by not returning them.\n";
    $prompt .= "- Preserve identity, tone, language policy, safety rules, operational limits, anti-hallucination rules, emergency rules, and voice-assistant constraints unless the customer request directly affects them.\n";
    $prompt .= "- Never shorten a returned section unless the customer explicitly asks to remove content.\n";
    $prompt .= "- Never invent facts, prices, opening hours, addresses, contacts, services, or availability not provided by the customer or already present.\n\n";

    $prompt .= "SELF-AUDIT BEFORE ANSWERING:\n";
    $prompt .= "Before producing JSON, check each updated fact as a consistency graph: direct values, examples, translations, spelling/pronunciation, punctuation notes, final-character warnings, recommendations, summaries, and negative/anti-error rules.\n";
    $prompt .= "Ask yourself: if a guest asks about this topic, could any section still produce the old answer? If yes, that section is affected and must be returned.\n";
    $prompt .= "Ask yourself: did I recompute derived text such as spelling, not just replace the visible value?\n";
    $prompt .= "Ask yourself: did I remove contradictions between old and new information?\n\n";

    $prompt .= "OUTPUT FORMAT — RETURN ONLY VALID JSON, NO MARKDOWN, NO CODE FENCES:\n";
    $prompt .= "{\n";
    $prompt .= "  \"request_type\": \"add|modify|replace|remove|mixed\",\n";
    $prompt .= "  \"changed_facts\": [\n";
    $prompt .= "    {\n";
