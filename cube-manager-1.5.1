if (!defined('ABSPATH')) {
    exit;
}

/**
 * Costanti base del plugin
 */
define('CUBE_MANAGER_VERSION', '1.5.1');
define('CUBE_MANAGER_PLUGIN_DIR', plugin_dir_path(__FILE__));
define('CUBE_MANAGER_PLUGIN_URL', plugin_dir_url(__FILE__));

/**
 * Attivazione plugin:
 * - crea ruolo cliente CUBE
 * - crea tabelle database
 */
function cube_manager_activate() {
    cube_manager_create_roles();
    cube_manager_create_tables();
    update_option('cube_manager_version', CUBE_MANAGER_VERSION);
}
register_activation_hook(__FILE__, 'cube_manager_activate');

/**
 * Aggiornamento leggero del plugin.
 * Serve quando carichi una nuova versione del file senza disattivare/riattivare il plugin.
 */
function cube_manager_maybe_upgrade() {
    $installed_version = get_option('cube_manager_version');

    if ($installed_version !== CUBE_MANAGER_VERSION) {
        cube_manager_create_roles();
        cube_manager_create_tables();
        update_option('cube_manager_version', CUBE_MANAGER_VERSION);
    }
}
add_action('admin_init', 'cube_manager_maybe_upgrade');

/**
 * Crea ruolo cliente CUBE.
 */
function cube_manager_create_roles() {
    add_role(
        'cube_customer',
        'Cliente CUBE',
        array(
            'read' => true,
            'cube_access_customer_area' => true,
        )
    );

    $admin_role = get_role('administrator');

    if ($admin_role) {
        $admin_role->add_cap('cube_manage_all');
        $admin_role->add_cap('cube_access_customer_area');
    }
}

/**
 * Crea le tabelle del plugin.
 */
function cube_manager_create_tables() {
    global $wpdb;

    require_once ABSPATH . 'wp-admin/includes/upgrade.php';

    $charset_collate = $wpdb->get_charset_collate();

    $structures_table = $wpdb->prefix . 'cube_structures';
    $devices_table    = $wpdb->prefix . 'cube_devices';
    $versions_table   = $wpdb->prefix . 'cube_define_versions';
    $keys_table       = $wpdb->prefix . 'cube_customer_keys';
    $logs_table       = $wpdb->prefix . 'cube_logs';

    $sql_structures = "CREATE TABLE $structures_table (
        id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
        user_id BIGINT(20) UNSIGNED NOT NULL,
        structure_name VARCHAR(190) NOT NULL,
        city VARCHAR(190) DEFAULT '',
        address TEXT DEFAULT NULL,
        weather_location VARCHAR(190) DEFAULT '',
        weather_label VARCHAR(190) DEFAULT '',
        base_instructions LONGTEXT DEFAULT NULL,
        status VARCHAR(50) NOT NULL DEFAULT 'active',
        created_at DATETIME NOT NULL,
        updated_at DATETIME NOT NULL,
        PRIMARY KEY  (id),
        KEY user_id (user_id),
        KEY status (status)
    ) $charset_collate;";

    $sql_devices = "CREATE TABLE $devices_table (
        id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
        structure_id BIGINT(20) UNSIGNED NOT NULL,
        device_code VARCHAR(190) NOT NULL,
        device_name VARCHAR(190) DEFAULT '',
        device_secret_hash VARCHAR(255) DEFAULT '',
        status VARCHAR(50) NOT NULL DEFAULT 'active',
        last_seen_at DATETIME DEFAULT NULL,
        current_define_version BIGINT(20) UNSIGNED DEFAULT NULL,
        created_at DATETIME NOT NULL,
        updated_at DATETIME NOT NULL,
        PRIMARY KEY  (id),
        UNIQUE KEY device_code (device_code),
        KEY structure_id (structure_id),
        KEY status (status)
    ) $charset_collate;";

    $sql_versions = "CREATE TABLE $versions_table (
        id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
        structure_id BIGINT(20) UNSIGNED NOT NULL,
        version_number INT UNSIGNED NOT NULL DEFAULT 1,
        uploaded_text LONGTEXT DEFAULT NULL,
        generated_instructions LONGTEXT DEFAULT NULL,
        generated_define LONGTEXT DEFAULT NULL,
        status VARCHAR(50) NOT NULL DEFAULT 'draft',
        created_by BIGINT(20) UNSIGNED DEFAULT NULL,
        approved_by BIGINT(20) UNSIGNED DEFAULT NULL,
        created_at DATETIME NOT NULL,
        approved_at DATETIME DEFAULT NULL,
        published_at DATETIME DEFAULT NULL,
        PRIMARY KEY  (id),
        KEY structure_id (structure_id),
        KEY status (status),
        KEY version_number (version_number)
    ) $charset_collate;";

    $sql_keys = "CREATE TABLE $keys_table (
        id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
        user_id BIGINT(20) UNSIGNED NOT NULL,
        structure_id BIGINT(20) UNSIGNED DEFAULT NULL,
        provider VARCHAR(50) NOT NULL DEFAULT 'openai',
        key_purpose VARCHAR(100) NOT NULL DEFAULT 'instructions',
        encrypted_api_key LONGTEXT DEFAULT NULL,
        key_status VARCHAR(50) NOT NULL DEFAULT 'inactive',
        created_at DATETIME NOT NULL,
        updated_at DATETIME NOT NULL,
        last_used_at DATETIME DEFAULT NULL,
        PRIMARY KEY  (id),
        KEY user_id (user_id),
        KEY structure_id (structure_id),
        KEY provider (provider),
        KEY key_status (key_status)
    ) $charset_collate;";

    $sql_logs = "CREATE TABLE $logs_table (
        id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
        device_id BIGINT(20) UNSIGNED DEFAULT NULL,
        structure_id BIGINT(20) UNSIGNED DEFAULT NULL,
        event_type VARCHAR(100) NOT NULL,
        message TEXT DEFAULT NULL,
        created_at DATETIME NOT NULL,
        PRIMARY KEY  (id),
        KEY device_id (device_id),
        KEY structure_id (structure_id),
        KEY event_type (event_type)
    ) $charset_collate;";

    dbDelta($sql_structures);
    dbDelta($sql_devices);
    dbDelta($sql_versions);
    dbDelta($sql_keys);
    dbDelta($sql_logs);
}

