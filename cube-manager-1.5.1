/**
 * Genera bozza INSTRUCTIONS con OpenAI per una richiesta.
 */
function cube_manager_handle_generate_instructions() {
    cube_manager_require_admin_permission();

    if (
        !isset($_GET['_wpnonce']) ||
        !wp_verify_nonce(
            sanitize_text_field(wp_unslash($_GET['_wpnonce'])),
            'cube_generate_instructions'
        )
    ) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'invalid_request')));
        exit;
    }

    $request_id = isset($_GET['request_id']) ? absint($_GET['request_id']) : 0;

    if ($request_id <= 0) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'invalid_request')));
        exit;
    }

    $request = cube_manager_get_update_request($request_id);

    if (!$request) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'invalid_request')));
        exit;
    }

    $key_record = cube_manager_get_structure_openai_key_record((int) $request->structure_id);

    if (!$key_record || $key_record->key_status !== 'active' || empty($key_record->encrypted_api_key)) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'ai_key_missing', 'view_request' => $request_id)));
        exit;
    }

    $api_key = cube_manager_decrypt_secret($key_record->encrypted_api_key);

    if (empty($api_key)) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'ai_key_decrypt_error', 'view_request' => $request_id)));
        exit;
    }

    $previous_instructions = cube_manager_get_latest_generated_instructions((int) $request->structure_id, $request_id);
    $generated = cube_manager_call_openai_for_instructions($api_key, $request, $previous_instructions);

    if (is_wp_error($generated)) {
        set_transient(
            'cube_last_ai_error_' . get_current_user_id(),
            $generated->get_error_message(),
            10 * MINUTE_IN_SECONDS
        );
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'ai_request_error', 'view_request' => $request_id)));
        exit;
    }

    if (empty($generated)) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'ai_empty_output', 'view_request' => $request_id)));
        exit;
    }

    global $wpdb;

    $versions_table = $wpdb->prefix . 'cube_define_versions';
    $keys_table = $wpdb->prefix . 'cube_customer_keys';

    $result = $wpdb->update(
        $versions_table,
        array(
            'generated_instructions' => $generated,
        ),
        array('id' => $request_id),
        array('%s'),
        array('%d')
    );

    $wpdb->update(
        $keys_table,
        array('last_used_at' => current_time('mysql')),
        array('id' => (int) $key_record->id),
        array('%s'),
        array('%d')
    );

    $message = ($result !== false) ? 'instructions_generated' : 'request_error';

    wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => $message, 'view_request' => $request_id)));
    exit;
}
add_action('admin_post_cube_manager_generate_instructions', 'cube_manager_handle_generate_instructions');

/**
 * Salva/modifica manualmente la bozza INSTRUCTIONS generata.
 */
function cube_manager_handle_save_generated_instructions() {
    cube_manager_require_admin_permission();

    $request_id = isset($_POST['request_id']) ? absint($_POST['request_id']) : 0;

    if ($request_id <= 0) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'invalid_request')));
        exit;
    }

    if (
        !isset($_POST['cube_generated_instructions_nonce']) ||
        !wp_verify_nonce(
            sanitize_text_field(wp_unslash($_POST['cube_generated_instructions_nonce'])),
            'cube_save_generated_instructions_' . $request_id
        )
    ) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'invalid_request', 'view_request' => $request_id)));
