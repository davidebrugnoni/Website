/**
 * -----------------------------------------------------------------------------
 * REST API dispositivi CUBE
 * -----------------------------------------------------------------------------
 * Endpoint principali:
 * - GET  /wp-json/cube/v1/device/define
 * - POST /wp-json/cube/v1/device/heartbeat
 *
 * Autenticazione tramite header:
 * - X-CUBE-DEVICE: codice dispositivo
 * - X-CUBE-TOKEN: token segreto dispositivo
 */
function cube_manager_register_rest_routes() {
    register_rest_route(
        'cube/v1',
        '/device/define',
        array(
            'methods'             => 'GET',
            'callback'            => 'cube_manager_rest_get_device_define',
            'permission_callback' => '__return_true',
        )
    );

    register_rest_route(
        'cube/v1',
        '/device/heartbeat',
        array(
            'methods'             => 'POST',
            'callback'            => 'cube_manager_rest_device_heartbeat',
            'permission_callback' => '__return_true',
        )
    );
}
add_action('rest_api_init', 'cube_manager_register_rest_routes');

/**
 * Log interno CUBE.
 */
function cube_manager_add_log($event_type, $message = '', $device_id = null, $structure_id = null) {
    global $wpdb;

    $logs_table = $wpdb->prefix . 'cube_logs';

    $wpdb->insert(
        $logs_table,
        array(
            'device_id'    => $device_id ? (int) $device_id : null,
            'structure_id' => $structure_id ? (int) $structure_id : null,
            'event_type'   => sanitize_text_field($event_type),
            'message'      => sanitize_textarea_field((string) $message),
            'created_at'   => current_time('mysql'),
        ),
        array('%d', '%d', '%s', '%s', '%s')
    );
}

/**
 * Recupera un dispositivo tramite device_code.
 */
function cube_manager_get_device_by_code($device_code) {
    global $wpdb;

    $devices_table = $wpdb->prefix . 'cube_devices';
    $device_code = cube_manager_normalize_device_code($device_code);

    if (empty($device_code)) {
        return null;
    }

    return $wpdb->get_row(
        $wpdb->prepare(
            "SELECT * FROM $devices_table WHERE device_code = %s LIMIT 1",
            $device_code
        )
    );
}

/**
 * Recupera l'ultima versione pubblicata del define.py per una struttura.
 */
function cube_manager_get_latest_published_define($structure_id) {
    global $wpdb;

    $versions_table = $wpdb->prefix . 'cube_define_versions';

    return $wpdb->get_row(
        $wpdb->prepare(
            "SELECT *
             FROM $versions_table
             WHERE structure_id = %d
             AND status = 'published'
             AND generated_define IS NOT NULL
             AND generated_define != ''
             ORDER BY version_number DESC, published_at DESC, id DESC
             LIMIT 1",
            (int) $structure_id
        )
    );
}

/**
 * Risposta REST standard per errori.
 */
function cube_manager_rest_error_response($code, $message, $status = 400) {
    $response = new WP_REST_Response(
        array(
            'success' => false,
            'error'   => $code,
            'message' => $message,
        ),
        $status
    );

    $response->header('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');

    return $response;
}

/**
 * Autenticazione dispositivo via header o parametri.
 */
function cube_manager_authenticate_rest_device(WP_REST_Request $request) {
    $device_code = $request->get_header('x-cube-device');
    $device_token = $request->get_header('x-cube-token');

    if (empty($device_code)) {
        $device_code = $request->get_param('device_code');
    }

    if (empty($device_token)) {
        $device_token = $request->get_param('device_secret');
    }

    $device_code = cube_manager_normalize_device_code((string) $device_code);
    $device_token = trim((string) $device_token);

    if (empty($device_code) || empty($device_token)) {
        return new WP_Error('missing_credentials', 'Credenziali dispositivo mancanti.', array('status' => 400));
    }

    $device = cube_manager_get_device_by_code($device_code);

    if (!$device) {
        cube_manager_add_log('invalid_device_code', 'Codice dispositivo non trovato: ' . $device_code);
        return new WP_Error('invalid_device', 'Dispositivo non trovato.', array('status' => 403));
    }

    if ($device->status !== 'active') {
        cube_manager_add_log('inactive_device', 'Tentativo accesso da dispositivo disattivo.', (int) $device->id, (int) $device->structure_id);
        return new WP_Error('inactive_device', 'Dispositivo non attivo.', array('status' => 403));
    }

    if (empty($device->device_secret_hash) || !wp_check_password($device_token, $device->device_secret_hash)) {
        cube_manager_add_log('invalid_device_token', 'Token dispositivo non valido.', (int) $device->id, (int) $device->structure_id);
        return new WP_Error('invalid_token', 'Token dispositivo non valido.', array('status' => 403));
    }

    $structure = cube_manager_get_structure((int) $device->structure_id);

    if (!$structure) {
        cube_manager_add_log('missing_structure', 'Struttura associata non trovata.', (int) $device->id, (int) $device->structure_id);
        return new WP_Error('missing_structure', 'Struttura associata non trovata.', array('status' => 404));
    }

    if ($structure->status !== 'active') {
        cube_manager_add_log('inactive_structure', 'Tentativo accesso a struttura disattiva.', (int) $device->id, (int) $structure->id);
        return new WP_Error('inactive_structure', 'Struttura non attiva.', array('status' => 403));
    }

    return array(
        'device'    => $device,
        'structure' => $structure,
    );
}

/**
 * Endpoint: scarica il define.py pubblicato per il dispositivo.
 */
function cube_manager_rest_get_device_define(WP_REST_Request $request) {
    global $wpdb;

    $auth = cube_manager_authenticate_rest_device($request);

    if (is_wp_error($auth)) {
        $data = $auth->get_error_data();
        $status = isset($data['status']) ? (int) $data['status'] : 400;
        return cube_manager_rest_error_response($auth->get_error_code(), $auth->get_error_message(), $status);
    }

    $device = $auth['device'];
    $structure = $auth['structure'];

    $latest_define = cube_manager_get_latest_published_define((int) $structure->id);

    if (!$latest_define || empty($latest_define->generated_define)) {
        cube_manager_add_log('define_not_found', 'Nessun define.py pubblicato per questa struttura.', (int) $device->id, (int) $structure->id);
        return cube_manager_rest_error_response('define_not_found', 'Nessun define.py pubblicato per questa struttura.', 404);
    }

    $now = current_time('mysql');
    $devices_table = $wpdb->prefix . 'cube_devices';

    $wpdb->update(
        $devices_table,
        array(
            'last_seen_at' => $now,
            'current_define_version' => (int) $latest_define->version_number,
            'updated_at' => $now,
        ),
        array('id' => (int) $device->id),
        array('%s', '%d', '%s'),
        array('%d')
    );

    cube_manager_add_log(
        'define_downloaded',
        'Scaricato define.py versione ' . (int) $latest_define->version_number . '.',
        (int) $device->id,
        (int) $structure->id
    );

    $define_content = (string) $latest_define->generated_define;

    $response = new WP_REST_Response(
        array(
            'success'        => true,
            'device_code'    => (string) $device->device_code,
            'structure_id'   => (int) $structure->id,
            'structure_name' => (string) $structure->structure_name,
            'version_number' => (int) $latest_define->version_number,
            'published_at'   => (string) $latest_define->published_at,
            'define_sha256'  => hash('sha256', $define_content),
            'define_py'      => $define_content,
        ),
        200
    );

    $response->header('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');

    return $response;
}

/**
 * Endpoint: heartbeat leggero del dispositivo.
 */
function cube_manager_rest_device_heartbeat(WP_REST_Request $request) {
    global $wpdb;

    $auth = cube_manager_authenticate_rest_device($request);

    if (is_wp_error($auth)) {
        $data = $auth->get_error_data();
        $status = isset($data['status']) ? (int) $data['status'] : 400;
        return cube_manager_rest_error_response($auth->get_error_code(), $auth->get_error_message(), $status);
    }

    $device = $auth['device'];
    $structure = $auth['structure'];
    $latest_define = cube_manager_get_latest_published_define((int) $structure->id);
    $latest_version = $latest_define ? (int) $latest_define->version_number : null;

    $now = current_time('mysql');
    $devices_table = $wpdb->prefix . 'cube_devices';

    $wpdb->update(
        $devices_table,
        array(
            'last_seen_at' => $now,
            'updated_at' => $now,
        ),
        array('id' => (int) $device->id),
        array('%s', '%s'),
        array('%d')
    );

    cube_manager_add_log('device_heartbeat', 'Heartbeat ricevuto dal dispositivo.', (int) $device->id, (int) $structure->id);

    $response = new WP_REST_Response(
        array(
            'success'                => true,
            'device_code'            => (string) $device->device_code,
            'structure_id'           => (int) $structure->id,
            'structure_name'         => (string) $structure->structure_name,
            'latest_define_version'  => $latest_version,
            'current_define_version' => !empty($device->current_define_version) ? (int) $device->current_define_version : null,
            'server_time'            => $now,
        ),
        200
    );

    $response->header('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');

    return $response;
}

