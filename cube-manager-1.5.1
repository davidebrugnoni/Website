/**
 * Recupera lista dispositivi con nome struttura.
 */
function cube_manager_get_devices() {
    global $wpdb;

    $devices_table = $wpdb->prefix . 'cube_devices';
    $structures_table = $wpdb->prefix . 'cube_structures';

    return $wpdb->get_results(
        "SELECT d.*, s.structure_name
         FROM $devices_table d
         LEFT JOIN $structures_table s ON d.structure_id = s.id
         ORDER BY d.created_at DESC"
