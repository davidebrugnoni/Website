/**
 * Converte un testo PHP in una stringa multilinea Python sicura con triple quotes.
 */
function cube_manager_python_multiline_string($value) {
    $value = (string) $value;
    $value = str_replace(array("\r\n", "\r"), "\n", $value);
    $value = str_replace('"""', '\\"\\"\\"', $value);

    return '"""' . $value . '"""';
}

/**
 * Policy lingua fissa del dispositivo.
 * Questa parte non viene modificata dal cliente.
 */
function cube_manager_get_fixed_language_policy() {
    return <<<'TXT'
# LANGUAGE POLICY — TOP PRIORITY

The assistant must answer in the same language as the user's latest clear request.

Use exactly one language per answer.
Do not mix languages in the same answer.
Do not translate the answer into another language unless the user explicitly asks for a translation.

There is no default response language.
Italian is not the default language.
The language of these instructions does not determine the response language.
The hotel location, city, country, brand names, room names, restaurant names, and proper nouns do not determine the response language.

## Language selection

If the user's latest clear request is in Italian, answer only in Italian.
If the user's latest clear request is in English, answer only in English.
If the user's latest clear request is in Spanish, answer only in Spanish.
If the user's latest clear request is in French, answer only in French.
If the user's latest clear request is in German, answer only in German.
If the user's latest clear request is in another clear language, answer in that language if you can do it well.

## Short request rule

Short requests are valid language signals.
Do not switch to Italian just because the request is short.

Examples:
- "Weather?", "What time?", "Time?", "Temperature?", "Breakfast?", "Restaurant?", "Wi-Fi?" -> answer in English.
- "Meteo?", "Che ore sono?", "Temperatura?", "Colazione?", "Ristorante?", "Wi-Fi?" -> answer in Italian.
- "¿Qué hora es?", "Tiempo?", "Temperatura?", "Desayuno?", "Restaurante?" -> answer in Spanish.
- "Météo?", "Quelle heure est-il?", "Température?", "Petit déjeuner?", "Restaurant?" -> answer in French.
- "Wetter?", "Wie spät ist es?", "Temperatur?", "Frühstück?", "Restaurant?" -> answer in German.

If a short request is ambiguous between multiple languages, answer in the most recent clear language used by the user in the current conversation.
Do not fall back to Italian unless there is no recent clear user language and the request is genuinely ambiguous.

## Mixed-language input

If the user mixes languages, answer in the dominant language of the user's latest request.
If the latest request contains only a foreign proper noun inside an otherwise Italian sentence, answer in Italian.
If the latest request contains only a foreign proper noun inside an otherwise English sentence, answer in English.

## Proper nouns

Proper names, hotel names, room names, restaurant names, brand names, place names, and the name CUBE may remain in their original form.
Everything else must stay in the user's response language.

## Noise and echo

Only answer to clear user speech.
If the audio is background noise, echo, or unclear speech, do not answer.
If you are unsure what the user said, ask for clarification in the most recent clear language used by the user.
TXT;
}

/**
 * Policy dati live fissa del dispositivo.
 * Questa parte non viene modificata dal cliente.
 */
function cube_manager_get_fixed_live_info_instructions() {
    return <<<'TXT'
# WEATHERAPI LIVE DATA POLICY

- THE ASSISTANT MUST ALWAYS ANSWER IN THE SAME LANGUAGE AS THE USER'S QUESTION.
- EVEN IF THE QUESTION IS SHORT, THE ASSISTANT MUST ANSWER IN THE SAME LANGUAGE AS THE QUESTION ASKED.
- NEVER ANSWER IN ITALIAN IF THE QUESTION WAS ASKED IN ANOTHER LANGUAGE.

When the user asks for information about:
- current time
- current day
- current date
- weather
- temperature
- rain
- wind
- atmospheric conditions

you must use exclusively the live information provided by WeatherAPI in the session context.

WeatherAPI information is the official and priority source for date, day, time and weather.

You must never invent, estimate or calculate date, day, time or weather on your own.
You must not say "I will check", "one moment", "let me verify", "wait" or similar phrases.
You must not say that you cannot access real-time information if WeatherAPI data is present in the context.
You must not use generic knowledge, previous data or assumptions.

If the user asks "what's the weather like?", "how is the weather?", "is it raining today?", "what's the temperature?", answer directly using the WeatherAPI weather data present in the context.

If the user asks "what time is it?", "what's the current time?", "can you tell me the time?", "what day is it today?" or "what's today's date?", answer directly using the date, day and time from the WeatherAPI context.

If the user asks for the weather or time without specifying a location, use the default location indicated in the WeatherAPI context.
TXT;
}

/**
 * Genera il contenuto finale del file define.py.
 * Le parti tecniche restano blindate; il cliente influenza solo INSTRUCTIONS e dati meteo struttura.
 * Mantiene la stessa logica del define.py base: LANGUAGE_POLICY e LIVE_INFO_INSTRUCTIONS
 * restano variabili separate, mentre INSTRUCTIONS contiene solo il blocco istruzioni finale.
 */
function cube_manager_build_define_py_content($structure, $instructions) {
    $weather_location = '';
    $weather_label = '';

    if ($structure) {
        $weather_location = trim((string) $structure->weather_location);
        $weather_label = trim((string) $structure->weather_label);
    }

    if ($weather_location === '') {
        $weather_location = '41.9028,12.4964';
    }

    if ($weather_label === '') {
        $weather_label = 'Roma, Italia';
    }

    $language_policy = cube_manager_get_fixed_language_policy();
    $live_info = cube_manager_get_fixed_live_info_instructions();
    $instructions = trim((string) $instructions);

    $define  = "import os\n\n";
    $define .= "NO_INTERNET_MESSAGE\t= \"Non riesco ad accedere ad internet, prova a riavviarmi\"\n";
    $define .= "# VOSK_MODEL\t\t\t= \"vosk-model-small-en-us-0.15\"\n";
    $define .= "REALTIME_MODEL\t\t= \"gpt-realtime-mini\"\n";
    $define .= "VOICE\t\t\t\t= \"marin\"\n";
    $define .= "# WAKE_WORDS\t\t\t= []\n";
    $define .= "# STOP_WORD\t\t\t= []\n";
    $define .= "RATE\t\t\t\t= 24000\n";
    $define .= "CHUNK\t\t\t\t= 2048\n";
    $define .= "PADDING_END\t\t\t= int(0.3 * RATE)\n";
    $define .= "BASE_DIR            = os.path.dirname(os.path.abspath(__file__))\n";
    $define .= "WAIT_CONNECTION_SOUND = os.path.join(BASE_DIR, \"audio\", \"attesa_connessione_en.wav\")\n";
    $define .= "ENABLE_SOUND        = os.path.join(BASE_DIR, \"audio\", \"enable.wav\")\n";
    $define .= "DISABLE_SOUND       = os.path.join(BASE_DIR, \"audio\", \"disable.wav\")\n";
    $define .= "# ---------------------------------------------------------------------\n";
    $define .= "# LIVE ONLINE INFO - WEATHERAPI\n";
    $define .= "# ---------------------------------------------------------------------\n";
    $define .= "WEATHER_DEFAULT_LOCATION = " . var_export($weather_location, true) . "\n\n";
    $define .= "WEATHER_DEFAULT_LOCATION_LABEL = " . var_export($weather_label, true) . "\n";
    $define .= "WEATHER_API_TIMEOUT = 5\n";
    $define .= "WEATHER_CACHE_TTL_SEC = 600\n";
    $define .= "WEATHER_LANGUAGE = \"it\"\n\n";
    $define .= "LANGUAGE_POLICY = " . cube_manager_python_multiline_string($language_policy) . "\n\n";
    $define .= "LIVE_INFO_INSTRUCTIONS = " . cube_manager_python_multiline_string($live_info) . "\n\n";
    $define .= "INSTRUCTIONS = " . cube_manager_python_multiline_string($instructions) . "\n";

    return $define;
}

/**
 * Pubblica il define.py finale per una richiesta approvata/generata.
 */
function cube_manager_handle_publish_define() {
    cube_manager_require_admin_permission();

    if (
        !isset($_GET['_wpnonce']) ||
        !wp_verify_nonce(
            sanitize_text_field(wp_unslash($_GET['_wpnonce'])),
            'cube_publish_define'
        )
    ) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'invalid_request')));
        exit;
    }

    $request_id = isset($_GET['request_id']) ? absint($_GET['request_id']) : 0;

    if ($request_id <= 0) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'invalid_request')));
        exit;
    }

    $request = cube_manager_get_update_request($request_id);

    if (!$request) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'invalid_request')));
        exit;
    }

    if ($request->status === 'rejected') {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'invalid_request', 'view_request' => $request_id)));
        exit;
    }

    $generated_instructions = trim((string) $request->generated_instructions);

    if ($generated_instructions === '') {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'instructions_missing', 'view_request' => $request_id)));
        exit;
    }

    $structure = cube_manager_get_structure((int) $request->structure_id);

    if (!$structure) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'define_error', 'view_request' => $request_id)));
        exit;
    }

    $define_content = cube_manager_build_define_py_content($structure, $generated_instructions);

    if (trim($define_content) === '') {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'define_error', 'view_request' => $request_id)));
        exit;
    }

    global $wpdb;

    $versions_table = $wpdb->prefix . 'cube_define_versions';
    $devices_table = $wpdb->prefix . 'cube_devices';
    $now = current_time('mysql');

    // Se esisteva già una versione pubblicata per questa struttura, la lasciamo come approvata/storica.
    $wpdb->query(
        $wpdb->prepare(
            "UPDATE $versions_table
             SET status = 'approved'
             WHERE structure_id = %d
             AND status = 'published'
             AND id != %d",
            (int) $request->structure_id,
            (int) $request_id
        )
    );

    $result = $wpdb->update(
        $versions_table,
        array(
            'generated_define' => $define_content,
            'status' => 'published',
            'approved_by' => get_current_user_id(),
            'approved_at' => !empty($request->approved_at) ? $request->approved_at : $now,
            'published_at' => $now,
        ),
        array('id' => $request_id),
        array('%s', '%s', '%d', '%s', '%s'),
        array('%d')
    );

    if ($result === false) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'define_error', 'view_request' => $request_id)));
        exit;
    }

    // Aggiorna la versione corrente mostrata sui dispositivi della struttura.
    $wpdb->update(
        $devices_table,
        array(
            'current_define_version' => (int) $request->version_number,
            'updated_at' => $now,
        ),
        array('structure_id' => (int) $request->structure_id),
        array('%d', '%s'),
        array('%d')
    );

    wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'define_published', 'view_request' => $request_id)));
    exit;
}
add_action('admin_post_cube_manager_publish_define', 'cube_manager_handle_publish_define');

