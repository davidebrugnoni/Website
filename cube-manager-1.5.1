/**
 * Invio richiesta aggiornamento istruzioni da area clienti.
 */
function cube_manager_handle_submit_update_request() {
    if (!is_user_logged_in()) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=login_required'));
        exit;
    }

    $user = wp_get_current_user();

    if (
        !in_array('cube_customer', (array) $user->roles, true) &&
        !current_user_can('cube_manage_all')
    ) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=not_allowed'));
        exit;
    }

    $structure_id = isset($_POST['structure_id']) ? absint($_POST['structure_id']) : 0;

    if ($structure_id <= 0 || !cube_manager_user_can_access_structure((int) $user->ID, $structure_id)) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=invalid_structure'));
        exit;
    }

    $nonce_action = 'cube_submit_update_request_' . $structure_id;

    if (
        !isset($_POST['cube_update_nonce']) ||
        !wp_verify_nonce(
            sanitize_text_field(wp_unslash($_POST['cube_update_nonce'])),
            $nonce_action
        )
    ) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=invalid_request'));
        exit;
    }

    $manual_text = isset($_POST['update_text'])
        ? sanitize_textarea_field(wp_unslash($_POST['update_text']))
        : '';

    $file_text = '';
    $file_error = '';

    if (
        isset($_FILES['update_file']) &&
        is_array($_FILES['update_file']) &&
        isset($_FILES['update_file']['error']) &&
        (int) $_FILES['update_file']['error'] !== UPLOAD_ERR_NO_FILE
    ) {
        $file = $_FILES['update_file'];

        if ((int) $file['error'] !== UPLOAD_ERR_OK) {
            $file_error = 'file_upload_error';
        } else {
            $file_name = isset($file['name']) ? sanitize_file_name($file['name']) : '';
            $file_size = isset($file['size']) ? (int) $file['size'] : 0;
            $file_tmp  = isset($file['tmp_name']) ? $file['tmp_name'] : '';
            $extension = strtolower(pathinfo($file_name, PATHINFO_EXTENSION));

            if ($extension !== 'txt') {
                $file_error = 'file_type_error';
            } elseif ($file_size > 100 * 1024) {
                $file_error = 'file_size_error';
            } elseif (!is_uploaded_file($file_tmp)) {
                $file_error = 'file_upload_error';
            } else {
                $raw_file_text = file_get_contents($file_tmp);
                if ($raw_file_text !== false) {
                    $file_text = sanitize_textarea_field($raw_file_text);
                }
            }
        }
    }

    if (!empty($file_error)) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=' . $file_error));
        exit;
    }

    $combined_text = '';

    if (!empty($manual_text)) {
        $combined_text .= "TESTO INSERITO DAL CLIENTE:\n" . $manual_text . "\n\n";
    }

    if (!empty($file_text)) {
        $combined_text .= "TESTO CARICATO DA FILE TXT:\n" . $file_text . "\n";
    }

    $combined_text = trim($combined_text);

    if (empty($combined_text)) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=empty_update'));
        exit;
    }

    global $wpdb;

    $versions_table = $wpdb->prefix . 'cube_define_versions';
    $now = current_time('mysql');
    $version_number = cube_manager_get_next_define_version_number($structure_id);

    $result = $wpdb->insert(
        $versions_table,
        array(
            'structure_id' => $structure_id,
            'version_number' => $version_number,
            'uploaded_text' => $combined_text,
            'generated_instructions' => null,
            'generated_define' => null,
            'status' => 'pending_approval',
            'created_by' => (int) $user->ID,
            'approved_by' => null,
            'created_at' => $now,
            'approved_at' => null,
            'published_at' => null,
        ),
        array(
            '%d', '%d', '%s', '%s', '%s', '%s', '%d', '%d', '%s', '%s', '%s'
        )
    );

    if ($result === false) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=request_error'));
        exit;
    }

    wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=request_sent'));
    exit;
}
add_action('admin_post_cube_manager_submit_update_request', 'cube_manager_handle_submit_update_request');

/**
 * Salvataggio struttura.
 */
function cube_manager_handle_save_structure() {
    cube_manager_require_admin_permission();

    if (
        !isset($_POST['cube_structure_nonce']) ||
        !wp_verify_nonce(
            sanitize_text_field(wp_unslash($_POST['cube_structure_nonce'])),
            'cube_save_structure'
        )
    ) {
        wp_safe_redirect(cube_manager_structures_url(array('cube_message' => 'invalid_request')));
        exit;
    }

    global $wpdb;

    $structures_table = $wpdb->prefix . 'cube_structures';

    $structure_id = isset($_POST['structure_id']) ? absint($_POST['structure_id']) : 0;
    $user_id = isset($_POST['user_id']) ? absint($_POST['user_id']) : 0;

    $structure_name = isset($_POST['structure_name'])
        ? sanitize_text_field(wp_unslash($_POST['structure_name']))
        : '';

    $city = isset($_POST['city'])
        ? sanitize_text_field(wp_unslash($_POST['city']))
        : '';

    $address = isset($_POST['address'])
        ? sanitize_textarea_field(wp_unslash($_POST['address']))
        : '';

    $weather_location = isset($_POST['weather_location'])
        ? sanitize_text_field(wp_unslash($_POST['weather_location']))
        : '';

    $weather_label = isset($_POST['weather_label'])
        ? sanitize_text_field(wp_unslash($_POST['weather_label']))
        : '';

    $base_instructions_raw = isset($_POST['base_instructions'])
        ? sanitize_textarea_field(wp_unslash($_POST['base_instructions']))
        : '';

    $base_instructions = cube_manager_extract_instructions_text($base_instructions_raw);

    $status = isset($_POST['status'])
        ? sanitize_text_field(wp_unslash($_POST['status']))
        : 'active';

    $allowed_statuses = array('active', 'inactive');

    if (!in_array($status, $allowed_statuses, true)) {
        $status = 'active';
    }

    if ($user_id <= 0 || empty($structure_name)) {
        wp_safe_redirect(cube_manager_structures_url(array('cube_message' => 'missing_fields')));
        exit;
    }

    $now = current_time('mysql');

    $data = array(
        'user_id'          => $user_id,
        'structure_name'   => $structure_name,
        'city'             => $city,
        'address'          => $address,
        'weather_location' => $weather_location,
        'weather_label'    => $weather_label,
        'base_instructions'=> $base_instructions,
        'status'           => $status,
        'updated_at'       => $now,
    );

    $formats = array(
        '%d',
        '%s',
        '%s',
        '%s',
        '%s',
        '%s',
        '%s',
        '%s',
        '%s',
    );

    if ($structure_id > 0) {
        $result = $wpdb->update(
            $structures_table,
            $data,
            array('id' => $structure_id),
            $formats,
            array('%d')
        );

        $message = ($result !== false) ? 'structure_updated' : 'structure_error';
    } else {
        $data['created_at'] = $now;
        $formats[] = '%s';

        $result = $wpdb->insert(
            $structures_table,
            $data,
            $formats
        );

        $message = ($result !== false) ? 'structure_created' : 'structure_error';
    }

    wp_safe_redirect(cube_manager_structures_url(array('cube_message' => $message)));
    exit;
}
add_action('admin_post_cube_manager_save_structure', 'cube_manager_handle_save_structure');

