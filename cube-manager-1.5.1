    }

    $generated_instructions = isset($_POST['generated_instructions'])
        ? wp_unslash($_POST['generated_instructions'])
        : '';

    $generated_instructions = trim((string) $generated_instructions);
    $triple_quotes = chr(34) . chr(34) . chr(34);
    $generated_instructions = str_replace($triple_quotes, '\"\"\"', $generated_instructions);

    if (empty($generated_instructions)) {
        wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => 'missing_fields', 'view_request' => $request_id)));
        exit;
    }

    global $wpdb;

    $versions_table = $wpdb->prefix . 'cube_define_versions';

    $result = $wpdb->update(
        $versions_table,
        array('generated_instructions' => $generated_instructions),
        array('id' => $request_id),
        array('%s'),
        array('%d')
    );

    $message = ($result !== false) ? 'instructions_saved' : 'request_error';

    wp_safe_redirect(cube_manager_approvals_url(array('cube_message' => $message, 'view_request' => $request_id)));
    exit;
