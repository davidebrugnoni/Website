    $prompt .= "      \"old_values_found\": [\"exact old value or old wording found in the current instructions\"],\n";
    $prompt .= "      \"new_values\": [\"exact new value or new wording requested by the customer\"],\n";
    $prompt .= "      \"derived_text_to_update\": [\"spelling/pronunciation/examples/translations/summaries connected to this fact\"]\n";
    $prompt .= "    }\n";
    $prompt .= "  ],\n";
    $prompt .= "  \"affected_sections\": [\n";
    $prompt .= "    {\"section_number\": \"7\", \"section_title\": \"WI-FI\", \"reason\": \"Main Wi-Fi section and derived spelling/example answers must be updated.\"}\n";
    $prompt .= "  ],\n";
    $prompt .= "  \"old_text_must_not_remain\": [\n";
    $prompt .= "    \"exact old value that must disappear from final instructions\"\n";
    $prompt .= "  ],\n";
    $prompt .= "  \"new_text_must_appear\": [\n";
    $prompt .= "    \"exact new value that must appear in final instructions\"\n";
    $prompt .= "  ],\n";
    $prompt .= "  \"section_replacements\": [\n";
    $prompt .= "    {\"section_number\": \"7\", \"new_section\": \"## 7. WI-FI\\n\\nComplete updated section text...\"}\n";
    $prompt .= "  ]\n";
    $prompt .= "}\n\n";

    $prompt .= "FIELD RULES:\n";
    $prompt .= "- old_text_must_not_remain must include old exact values that should fully disappear after replacement, especially old passwords, phone numbers, websites, coupons, addresses, code words, names, and outdated rules.\n";
    $prompt .= "- Include old derived text when it can remain contradictory, for example old password spelling or old example answers.\n";
    $prompt .= "- Do NOT put old text in old_text_must_not_remain if the customer explicitly wants it preserved as a negative/invalid example.\n";
    $prompt .= "- new_text_must_appear must include ONLY short atomic values that are objectively required, such as the new password, new phone number, new website, new coupon, new address, or new internal code word.\n";
    $prompt .= "- Do NOT put full sentences, examples, or generated wording inside new_text_must_appear. Those belong inside section_replacements only.\n";
    $prompt .= "- The plugin may validate new_text_must_appear literally, so keep it short and atomic. Example: use 'martello', not 'The word “martello” is an internal code word.'.\n";
    $prompt .= "- section_replacements must contain complete updated sections only.\n";
    $prompt .= "- Every new_section must start with the original heading format, for example: ## 7. WI-FI.\n";
    $prompt .= "- If no change is needed, return empty arrays.\n";

    return $prompt;
}

/**
 * Rimuove eventuali code fence e prova a decodificare JSON.
 */
function cube_manager_decode_json_patch_text($text) {
    $text = trim((string) $text);
    $text = preg_replace('/^```(?:json)?\s*/i', '', $text);
    $text = preg_replace('/\s*```$/', '', $text);
    $text = trim($text);

    $data = json_decode($text, true);

    if (is_array($data)) {
        return $data;
    }

    $start = strpos($text, '{');
    $end = strrpos($text, '}');

    if ($start !== false && $end !== false && $end > $start) {
        $candidate = substr($text, $start, $end - $start + 1);
        $data = json_decode($candidate, true);

        if (is_array($data)) {
            return $data;
        }
    }

    return null;
}

/**
 * Sostituisce una sezione numerata markdown, per esempio ## 29. ... fino alla sezione successiva.
 */
function cube_manager_replace_numbered_instruction_section($instructions, $section_number, $new_section) {
    $section_number = trim((string) $section_number);
    $new_section = trim((string) $new_section);

    if ($section_number === '' || $new_section === '') {
        return false;
    }

    if (!preg_match('/^##\s*' . preg_quote($section_number, '/') . '\.\s+/m', $new_section)) {
        return false;
    }

    $pattern = '/(^##\s*' . preg_quote($section_number, '/') . '\.\s[\s\S]*?)(?=\n---\s*\R\R##\s*\d+\.\s+|\z)/m';

    if (!preg_match($pattern, $instructions)) {
        return false;
    }

    return preg_replace($pattern, $new_section, $instructions, 1);
}

/**
 * Verifica che le sezioni non modificate siano rimaste identiche.
 */
function cube_manager_validate_unchanged_sections($original_instructions, $patched_instructions, $changed_section_numbers) {
    $original_sections = cube_manager_extract_instruction_sections($original_instructions);
    $patched_sections = cube_manager_extract_instruction_sections($patched_instructions);
    $changed_lookup = array();

    foreach ($changed_section_numbers as $number) {
        $changed_lookup[(string) $number] = true;
    }

    foreach ($original_sections as $number => $section) {
        if (isset($changed_lookup[(string) $number])) {
            continue;
        }

        if (!isset($patched_sections[$number])) {
            return new WP_Error('section_missing_after_patch', 'La sezione ' . $number . ' manca dopo la modifica.');
        }

        if (trim((string) $patched_sections[$number]['text']) !== trim((string) $section['text'])) {
            return new WP_Error('unchanged_section_modified', 'La sezione ' . $number . ' è stata modificata anche se non era tra quelle coinvolte.');
        }
    }

    return true;
}

/**
 * Applica le sezioni restituite da OpenAI al prompt completo.
 */
function cube_manager_apply_instructions_patch($current_instructions, $patch_data) {
    $edited = (string) $current_instructions;

    if (!is_array($patch_data)) {
        return new WP_Error('invalid_patch', 'Risposta JSON non valida.');
    }

    $replacements = array();

    if (!empty($patch_data['section_replacements']) && is_array($patch_data['section_replacements'])) {
        $replacements = $patch_data['section_replacements'];
    } elseif (!empty($patch_data['operations']) && is_array($patch_data['operations'])) {
        // Compatibilità con versioni precedenti del prompt.
        foreach ($patch_data['operations'] as $operation) {
            if (is_array($operation) && isset($operation['type']) && $operation['type'] === 'replace_section') {
                $replacements[] = array(
                    'section_number' => isset($operation['section_number']) ? $operation['section_number'] : '',
                    'new_section' => isset($operation['new_section']) ? $operation['new_section'] : '',
                );
            }
        }
    }

    if (empty($replacements)) {
        return new WP_Error('no_section_replacements', 'OpenAI non ha restituito sezioni da sostituire.');
    }

    $changed_section_numbers = array();
    $applied_count = 0;

    foreach ($replacements as $replacement) {
        if (!is_array($replacement)) {
            continue;
        }

        $section_number = isset($replacement['section_number']) ? (string) $replacement['section_number'] : '';
        $new_section = isset($replacement['new_section']) ? (string) $replacement['new_section'] : '';

        if ($section_number === '' || trim($new_section) === '') {
            continue;
        }

        $replaced = cube_manager_replace_numbered_instruction_section($edited, $section_number, $new_section);

        if ($replaced !== false) {
            $edited = $replaced;
            $changed_section_numbers[] = $section_number;
            $applied_count++;
        }
    }

    if ($applied_count <= 0) {
        return new WP_Error('patch_not_applied', 'Nessuna sezione restituita da OpenAI è stata applicata.');
    }

    $unchanged_validation = cube_manager_validate_unchanged_sections($current_instructions, $edited, $changed_section_numbers);

    if (is_wp_error($unchanged_validation)) {
        return $unchanged_validation;
    }

    return trim($edited);
}

/**
 * Estrae testo da una risposta OpenAI Responses API in modo tollerante.
 */
function cube_manager_extract_openai_text($data) {
    if (isset($data['output_text']) && is_string($data['output_text']) && trim($data['output_text']) !== '') {
        return trim($data['output_text']);
    }

    $texts = array();

    if (isset($data['output']) && is_array($data['output'])) {
        foreach ($data['output'] as $item) {
            if (!isset($item['content']) || !is_array($item['content'])) {
                continue;
            }

            foreach ($item['content'] as $content) {
                if (isset($content['text']) && is_string($content['text'])) {
                    $texts[] = $content['text'];
                }
            }
        }
    }

    return trim(implode("\n", $texts));
}


/**
 * Esegue una chiamata a OpenAI Responses API e restituisce il testo prodotto.
 */
function cube_manager_openai_responses_text($api_key, $prompt, $system_content) {
    $payload = array(
        'model' => 'gpt-5.4-mini',
        'input' => array(
            array(
                'role' => 'system',
                'content' => $system_content
            ),
            array(
                'role' => 'user',
                'content' => $prompt
            )
        ),
        'max_output_tokens' => 10000,
    );

    $response = wp_remote_post(
        'https://api.openai.com/v1/responses',
        array(
            'timeout' => 240,
            'headers' => array(
                'Authorization' => 'Bearer ' . $api_key,
                'Content-Type' => 'application/json',
            ),
            'body' => wp_json_encode($payload),
        )
    );

    if (is_wp_error($response)) {
        return $response;
    }

    $status_code = (int) wp_remote_retrieve_response_code($response);
    $body = wp_remote_retrieve_body($response);
    $data = json_decode($body, true);

    if ($status_code < 200 || $status_code >= 300) {
        $message = 'OpenAI error';

        if (is_array($data) && isset($data['error']['message'])) {
            $message = (string) $data['error']['message'];
        }

        return new WP_Error('openai_error', $message);
    }

    if (!is_array($data)) {
        return new WP_Error('openai_invalid_json', 'Invalid JSON response from OpenAI');
    }

    $text = cube_manager_extract_openai_text($data);

    if (empty($text)) {
        return new WP_Error('openai_empty_output', 'Empty output from OpenAI');
    }

    return $text;
}

/**
 * Normalizza testo per controlli di presenza robusti ma semplici.
 */
function cube_manager_normalize_for_presence_check($text) {
    $text = (string) $text;
    $text = str_replace(array('“', '”', '‘', '’'), array('"', '"', "'", "'"), $text);
    $text = html_entity_decode($text, ENT_QUOTES | ENT_HTML5, 'UTF-8');
    $text = preg_replace('/\s+/u', ' ', $text);
    return mb_strtolower(trim($text), 'UTF-8');
}

/**
 * Controlla se un testo contiene una stringa, con normalizzazione base.
 */
function cube_manager_text_contains_normalized($haystack, $needle) {
    $needle = trim((string) $needle);

    if ($needle === '') {
        return true;
    }

    $haystack_n = cube_manager_normalize_for_presence_check($haystack);
    $needle_n = cube_manager_normalize_for_presence_check($needle);

    return strpos($haystack_n, $needle_n) !== false;
}


/**
 * Prova a estrarre dalla patch AI il nuovo valore della password Wi-Fi.
 * Serve per controlli mirati sulle contraddizioni più frequenti: spelling e punteggiatura finale.
 */
function cube_manager_extract_new_wifi_password_from_patch($patch_data) {
    if (!is_array($patch_data)) {
        return '';
    }

    $candidates = array();
    $wifi_context_found = false;

    if (!empty($patch_data['changed_facts']) && is_array($patch_data['changed_facts'])) {
        foreach ($patch_data['changed_facts'] as $fact) {
            if (!is_array($fact)) {
                continue;
            }

            $topic = isset($fact['topic']) ? cube_manager_normalize_for_presence_check($fact['topic']) : '';

            if ((strpos($topic, 'wi-fi') !== false || strpos($topic, 'wifi') !== false) && strpos($topic, 'password') !== false) {
                $wifi_context_found = true;

                if (!empty($fact['new_values']) && is_array($fact['new_values'])) {
                    foreach ($fact['new_values'] as $value) {
                        $candidates[] = (string) $value;
                    }
                }
            }
        }
    }

    if (!$wifi_context_found && !empty($patch_data['affected_sections']) && is_array($patch_data['affected_sections'])) {
        foreach ($patch_data['affected_sections'] as $section) {
            if (!is_array($section)) {
                continue;
            }

            $section_number = isset($section['section_number']) ? (string) $section['section_number'] : '';
            $section_title = isset($section['section_title']) ? cube_manager_normalize_for_presence_check($section['section_title']) : '';

            if ($section_number === '7' || strpos($section_title, 'wi-fi') !== false || strpos($section_title, 'wifi') !== false) {
                $wifi_context_found = true;
                break;
            }
        }
    }

    if ($wifi_context_found && !empty($patch_data['new_text_must_appear']) && is_array($patch_data['new_text_must_appear'])) {
        foreach ($patch_data['new_text_must_appear'] as $value) {
            $candidates[] = (string) $value;
        }
    }

    foreach ($candidates as $candidate) {
        $candidate = trim($candidate, " \t\n\r\0\x0B\"'“”‘’");

        if ($candidate === '') {
            continue;
        }

        // Le password nei nostri prompt sono normalmente brevi, senza spazi,
        // e spesso contengono numeri o simboli. Evitiamo di prendere frasi intere.
        if (strlen($candidate) <= 80 && preg_match('/^[^\s]+$/u', $candidate) && preg_match('/[0-9!$@#%&*?._\-]/u', $candidate)) {
            return $candidate;
        }
    }

    return '';
}

/**
 * Controllo mirato per evitare incoerenze evidenti quando cambia la password Wi-Fi.
 * Esempio reale: nuova password pincopallo17$ ma sezione rimasta con "final exclamation mark".
 */
function cube_manager_validate_wifi_password_consistency($patched_instructions, $patch_data) {
    $new_password = cube_manager_extract_new_wifi_password_from_patch($patch_data);

    if ($new_password === '') {
        return true;
    }

    $last_char = substr($new_password, -1);
    $text = cube_manager_normalize_for_presence_check($patched_instructions);

    if ($last_char !== '!' && (strpos($text, 'exclamation mark') !== false || strpos($text, 'punto esclamativo') !== false)) {
        return new WP_Error(
            'wifi_password_final_character_contradiction',
            'La nuova password Wi-Fi è "' . $new_password . '", ma nelle istruzioni resta un riferimento al punto esclamativo finale.'
        );
    }

    if ($last_char === '$') {
        $has_dollar_reference = (
            strpos($text, 'dollar sign') !== false ||
            strpos($text, 'simbolo del dollaro') !== false ||
            strpos($text, 'dollaro finale') !== false
        );

        if (!$has_dollar_reference) {
            return new WP_Error(
                'wifi_password_missing_dollar_reference',
                'La nuova password Wi-Fi termina con "$", ma le istruzioni non spiegano il simbolo del dollaro finale.'
            );
        }
    }

    return true;
}


/**
 * Decide se una voce new_text_must_appear può essere validata letteralmente.
 * OpenAI a volte inserisce frasi lunghe generate in questo campo: quelle non devono bloccare la bozza.
 * Qui validiamo solo valori atomici: password, codice, parola chiave, telefono, sito, coupon, ecc.
 */
function cube_manager_is_atomic_required_text($value) {
    $value = trim((string) $value);

    if ($value === '') {
        return false;
    }

    if (mb_strlen($value, 'UTF-8') > 80) {
        return false;
    }

    if (strpos($value, "\n") !== false || strpos($value, "\r") !== false) {
        return false;
    }

    // Frasi complete o esempi lunghi: non sono valori atomici.
    $word_count = preg_match_all('/\S+/u', $value);
    if ($word_count > 5) {
        return false;
    }

    // Se sembra una frase con verbo/struttura discorsiva, non la validiamo letteralmente.
    $normalized = cube_manager_normalize_for_presence_check($value);
    $sentence_markers = array(' the ', ' when ', ' user:', ' chiùb:', ' must ', ' should ', ' is an ', ' la ', ' il ', ' deve ', ' quando ');
    foreach ($sentence_markers as $marker) {
        if (strpos(' ' . $normalized . ' ', $marker) !== false && $word_count > 2) {
            return false;
        }
    }

    return true;
}

/**
 * Estrae una nuova parola chiave interna dalla richiesta del gestore.
 * Serve solo come stabilizzatore finale se OpenAI fallisce la sezione della parola interna.
 */
function cube_manager_extract_internal_code_word_from_request($request_text) {
    $request_text = (string) $request_text;
    $normalized = cube_manager_normalize_for_presence_check($request_text);

    $looks_like_code_word_request = (
        strpos($normalized, 'parola chiave') !== false ||
        strpos($normalized, 'code word') !== false ||
        strpos($normalized, 'internal code') !== false ||
        strpos($normalized, 'codice interno') !== false
    );

    $looks_like_cleaning = (
        strpos($normalized, 'puliz') !== false ||
        strpos($normalized, 'cleaning') !== false ||
        strpos($normalized, 'impresa') !== false
    );

    if (!$looks_like_code_word_request || !$looks_like_cleaning) {
        return '';
    }

    preg_match_all('/["“”\']([^"“”\']{2,80})["“”\']/u', $request_text, $matches);

    if (!empty($matches[1])) {
        $candidate = trim(end($matches[1]));
        if ($candidate !== '') {
            return $candidate;
        }
    }

    // Fallback molto semplice per frasi senza virgolette: "... è martello" / "... diventa martello".
    if (preg_match('/(?:è|e\'|sia|diventa|sarà|sara|is|becomes)\s+([A-Za-zÀ-ÿ0-9_\- ]{3,40})/u', $request_text, $m)) {
        return trim($m[1], " .,!?:;\t\n\r\0\x0B");
    }

    return '';
}

/**
 * Costruisce una sezione 29 robusta mantenendo la procedura esistente.
 * Usata solo come fallback di stabilità se OpenAI non applica la parola interna richiesta.
 */
function cube_manager_build_internal_code_word_section($previous_instructions, $new_word) {
    $new_word = trim((string) $new_word);
    $sections = cube_manager_extract_instruction_sections($previous_instructions);
    $old_section = isset($sections['29']['text']) ? (string) $sections['29']['text'] : '';

    $procedure = 'Quick cleaning procedure: air the rooms, make the bed, check the bathroom and kitchen, empty the bins, check towels and toilet paper, clean the main surfaces, and make sure remotes, vouchers, welcome products, and amenities are in order. Before leaving, check lights, windows, terrace, and entrance door.';

    if (preg_match('/Chiùb must respond only with this text:\s*[\r\n]+[“"](.+?)[”"]/su', $old_section, $m)) {
        $procedure = trim($m[1]);
    }

    $section  = '## 29. INTERNAL CODE WORD — “' . $new_word . "”\n\n";
    $section .= 'The word “' . $new_word . "” is the only valid internal code word.\n\n";
    $section .= 'When the user says only “' . $new_word . '”, or says “Chiùb, ' . $new_word . "”, Chiùb must ignore the normal meaning of the word and immediately activate the internal cleaning procedure.\n\n";
    $section .= 'No other word can activate the internal cleaning procedure. Previous internal code words are no longer valid. Similar words, category-related words, gemstone names, object names, or old code words must not activate the procedure unless they are exactly “' . $new_word . '” or exactly “Chiùb, ' . $new_word . "”.\n\n";
    $section .= 'In this case, Chiùb must never explain what “' . $new_word . "” means.\n";
    $section .= "Chiùb must not talk about the normal meaning of the word.\n";
    $section .= "Chiùb must not ask clarification questions.\n";
    $section .= "Chiùb must not answer generically.\n\n";
    $section .= "Chiùb must respond only with this text:\n\n";
    $section .= '“' . $procedure . "”\n\n";
    $section .= "Anti-error rule:\n";
    $section .= 'If the phrase contains the word “' . $new_word . '” alone, or preceded by the name “Chiùb”, the correct answer is always the cleaning procedure, not an explanation of the word.' . "\n\n";
    $section .= "Examples:\n";
    $section .= 'User: “' . $new_word . "”\n";
    $section .= "Chiùb: must give the cleaning procedure.\n\n";
    $section .= 'User: “Chiùb, ' . $new_word . "”\n";
    $section .= "Chiùb: must give the cleaning procedure.\n\n";
    $section .= 'User: “What does ' . $new_word . " mean?”\n";
    $section .= "Chiùb: may explain the meaning, because in this case the word is used as an explicit question, not as the internal code.\n\n";
    $section .= "Recommended internal command:\n";
    $section .= '“Chiùb, ' . $new_word . "”";

    return $section;
}

/**
 * Fallback finale: se OpenAI non riesce ad applicare una nuova parola interna,
 * sostituiamo solo la sezione 29 in modo deterministico, mantenendo il prompt completo.
 */
function cube_manager_try_internal_code_word_fallback($request, $previous_instructions) {
    $uploaded_text = isset($request->uploaded_text) ? (string) $request->uploaded_text : '';
    $new_word = cube_manager_extract_internal_code_word_from_request($uploaded_text);

    if ($new_word === '') {
        return new WP_Error('no_internal_code_word_fallback', 'Fallback parola interna non applicabile.');
    }

    $new_section = cube_manager_build_internal_code_word_section($previous_instructions, $new_word);

    $patch_data = array(
        'section_replacements' => array(
            array(
                'section_number' => '29',
                'new_section' => $new_section,
            ),
        ),
        'new_text_must_appear' => array($new_word),
        'old_text_must_not_remain' => array(),
    );

    $patched = cube_manager_apply_instructions_patch($previous_instructions, $patch_data);

    if (is_wp_error($patched)) {
        return $patched;
    }

    if (!cube_manager_instruction_looks_complete($patched, $previous_instructions)) {
        return new WP_Error('fallback_incomplete', 'Fallback parola interna incompleto rispetto alle istruzioni sorgente.');
    }

    return array(
        'patched_instructions' => $patched,
        'patch_data' => $patch_data,
    );
}

/**
 * Verifica i requisiti dichiarati dalla patch AI: nuovi testi presenti e vecchi testi assenti.
 */
function cube_manager_validate_patch_requirements($patched_instructions, $patch_data) {
    // Versione stabile: questa funzione NON deve più bloccare la generazione della bozza.
    // Nelle versioni precedenti il validatore fermava tutto per falsi positivi tipo:
    // "Nuovi testi mancanti: martello" oppure vecchi testi rimasti come esempi negativi.
    // Questo faceva sembrare un errore OpenAI/chiave/credito anche quando la chiamata era riuscita.
    //
    // La qualità ora deve essere gestita principalmente da:
    // 1. prompt di editing più rigoroso;
    // 2. ricostruzione del prompt completo tramite sostituzione sezioni;
    // 3. controllo umano dell'admin prima della pubblicazione;
    // 4. fallback deterministico per casi semplici e critici, come la parola interna di pulizia.
    //
    // Non restituiamo più WP_Error per new_text_must_appear / old_text_must_not_remain.
    return true;
}

/**
 * Costruisce un contesto di riparazione se la prima patch lascia incoerenze.
 */
function cube_manager_build_repair_context($patch_data, $patched_instructions, $validation_error) {
    $context  = "The previous JSON patch was incomplete or inconsistent.\n";
    $context .= "Validation error:\n" . $validation_error->get_error_message() . "\n\n";
    $context .= "Previous JSON patch:\n" . wp_json_encode($patch_data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . "\n\n";
    $context .= "Failed rebuilt instructions draft:\n" . $patched_instructions . "\n\n";
    $context .= "Return a corrected JSON patch. You must include every section needed to remove contradictions and apply the customer request completely.\n";
    return $context;
}

/**
 * Decodifica JSON patch, applica le sezioni e valida completezza/coerenza.
 */
function cube_manager_decode_apply_and_validate_patch($text, $previous_instructions) {
    $patch_data = cube_manager_decode_json_patch_text($text);

    if (!is_array($patch_data)) {
        return new WP_Error('openai_invalid_patch_json', 'OpenAI non ha restituito un JSON valido con le sezioni da aggiornare.');
    }

    $patched = cube_manager_apply_instructions_patch($previous_instructions, $patch_data);

    if (is_wp_error($patched)) {
        return $patched;
    }

    if (!cube_manager_instruction_looks_complete($patched, $previous_instructions)) {
        return new WP_Error('patched_instructions_incomplete', 'La bozza generata sembra incompleta rispetto alle istruzioni sorgente.');
    }

    $semantic_validation = cube_manager_validate_patch_requirements($patched, $patch_data);

    if (is_wp_error($semantic_validation)) {
        return new WP_Error(
            'semantic_validation_failed',
            $semantic_validation->get_error_message(),
            array(
                'patch_data' => $patch_data,
                'patched_instructions' => $patched,
            )
        );
    }

    return array(
        'patched_instructions' => $patched,
        'patch_data' => $patch_data,
    );
}


/**
 * Costruisce un prompt di audit finale: OpenAI deve controllare il prompt completo ricostruito
 * e correggere eventuali sezioni ancora incoerenti o incomplete.
 */
function cube_manager_build_final_consistency_audit_prompt($request, $original_instructions, $patched_instructions, $previous_patch_data = array(), $retry_context = '') {
    $structure_name = isset($request->structure_name) ? (string) $request->structure_name : '';
    $city = isset($request->city) ? (string) $request->city : '';
    $uploaded_text = isset($request->uploaded_text) ? (string) $request->uploaded_text : '';
    $sections_index = cube_manager_build_sections_index_for_ai($original_instructions);

    $prompt  = "You are the final QA auditor for a structured CUBE hospitality assistant prompt.\n";
    $prompt .= "Your job is to verify whether the rebuilt complete instructions fully and consistently apply the customer request.\n";
    $prompt .= "You must be strict. If any old information, old example, old spelling, old translation, old recommendation, or old derived wording remains, you must return the additional complete sections to replace.\n\n";

    $prompt .= "STRUCTURE CONTEXT:\n";
    $prompt .= "Structure name: " . $structure_name . "\n";
    $prompt .= "City: " . $city . "\n\n";

    $prompt .= "SECTION INDEX:\n";
    $prompt .= $sections_index . "\n\n";

    $prompt .= "CUSTOMER UPDATE REQUEST:\n";
    $prompt .= $uploaded_text . "\n\n";

    $prompt .= "ORIGINAL COMPLETE INSTRUCTIONS BEFORE UPDATE:\n";
    $prompt .= trim((string) $original_instructions) . "\n\n";

    $prompt .= "FIRST PATCH JSON USED TO PRODUCE THE DRAFT:\n";
    $prompt .= wp_json_encode($previous_patch_data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . "\n\n";

    $prompt .= "REBUILT COMPLETE INSTRUCTIONS DRAFT TO AUDIT:\n";
    $prompt .= trim((string) $patched_instructions) . "\n\n";

    if (trim((string) $retry_context) !== '') {
        $prompt .= "RETRY CONTEXT:\n";
        $prompt .= (string) $retry_context . "\n\n";
    }

    $prompt .= "AUDIT RULES:\n";
    $prompt .= "- Determine whether the draft fully applies the customer request everywhere.\n";
    $prompt .= "- Check direct occurrences and indirect/derived occurrences: examples, translations, recommended answers, spelling, pronunciation, summaries, anti-error rules, suggestions, and cross-references.\n";
    $prompt .= "- For a changed Wi-Fi password, verify the actual password, English answer, Italian answer, repeat/spelling answer, and any tone-of-voice example. The spelling must match the new password, not the old one.\n";
    $prompt .= "- For a changed place, contact, restaurant, coupon, website, internal code word, service, address, host name, or rule, verify all related sections and guest-facing examples.\n";
    $prompt .= "- If the draft is incomplete, return only additional complete section replacements needed to fix it.\n";
    $prompt .= "- If the draft is complete, return is_complete true and an empty additional_section_replacements array.\n";
    $prompt .= "- Never return the full prompt. Never summarize. Return only valid JSON.\n\n";

    $prompt .= "OUTPUT FORMAT — RETURN ONLY VALID JSON, NO MARKDOWN, NO CODE FENCES:\n";
    $prompt .= "{\n";
    $prompt .= "  \"is_complete\": true,\n";
    $prompt .= "  \"issues\": [\"description of any remaining inconsistency\"],\n";
    $prompt .= "  \"old_text_must_not_remain\": [\"old exact text that still must disappear\"],\n";
    $prompt .= "  \"new_text_must_appear\": [\"new exact text or derived text that must appear\"],\n";
    $prompt .= "  \"additional_section_replacements\": [\n";
    $prompt .= "    {\"section_number\": \"7\", \"new_section\": \"## 7. WI-FI\\n\\nComplete corrected section text...\"}\n";
    $prompt .= "  ]\n";
    $prompt .= "}\n";

    return $prompt;
}

/**
 * Applica eventuali correzioni dell'audit finale e ripete il controllo massimo due volte.
 */
function cube_manager_run_final_consistency_audit($api_key, $request, $original_instructions, $patched_instructions, $patch_data, $system_content) {
    $current = trim((string) $patched_instructions);
    $last_audit_data = array();
    $retry_context = '';

    for ($attempt = 1; $attempt <= 2; $attempt++) {
        $audit_prompt = cube_manager_build_final_consistency_audit_prompt(
            $request,
            $original_instructions,
            $current,
            $patch_data,
            $retry_context
        );

        $audit_text = cube_manager_openai_responses_text($api_key, $audit_prompt, $system_content);

        if (is_wp_error($audit_text)) {
            return $audit_text;
        }

        $audit_data = cube_manager_decode_json_patch_text($audit_text);

        if (!is_array($audit_data)) {
            return new WP_Error('openai_invalid_audit_json', 'OpenAI non ha restituito un JSON valido durante il controllo finale.');
        }

        $last_audit_data = $audit_data;
        $additional = array();

        if (!empty($audit_data['additional_section_replacements']) && is_array($audit_data['additional_section_replacements'])) {
            $additional = $audit_data['additional_section_replacements'];
        }

        if (!empty($additional)) {
            $audit_patch = array(
                'section_replacements' => $additional,
                'old_text_must_not_remain' => isset($audit_data['old_text_must_not_remain']) ? $audit_data['old_text_must_not_remain'] : array(),
                'new_text_must_appear' => isset($audit_data['new_text_must_appear']) ? $audit_data['new_text_must_appear'] : array(),
            );

            $fixed = cube_manager_apply_instructions_patch($current, $audit_patch);

            if (is_wp_error($fixed)) {
                return $fixed;
            }

            if (!cube_manager_instruction_looks_complete($fixed, $original_instructions)) {
                return new WP_Error('audited_instructions_incomplete', 'La bozza corretta dall’audit sembra incompleta rispetto alle istruzioni sorgente.');
            }

            $requirements_validation = cube_manager_validate_patch_requirements($fixed, $audit_patch);

            if (is_wp_error($requirements_validation)) {
                $retry_context = "The previous audit correction still failed validation: " . $requirements_validation->get_error_message();
                $current = trim($fixed);
                continue;
            }

            $current = trim($fixed);
            $retry_context = "A previous audit returned additional section replacements. Verify the newly corrected draft again strictly.";
            continue;
        }

        $is_complete = isset($audit_data['is_complete']) ? (bool) $audit_data['is_complete'] : false;

        $requirements_validation = cube_manager_validate_patch_requirements($current, array(
            'old_text_must_not_remain' => isset($audit_data['old_text_must_not_remain']) ? $audit_data['old_text_must_not_remain'] : array(),
            'new_text_must_appear' => isset($audit_data['new_text_must_appear']) ? $audit_data['new_text_must_appear'] : array(),
        ));

        if (is_wp_error($requirements_validation)) {
            $retry_context = "The audit declared requirements that the draft does not satisfy: " . $requirements_validation->get_error_message() . " Return additional_section_replacements to fix it.";
            continue;
        }

        if ($is_complete) {
            return $current;
        }

        $issues = array();
        if (!empty($audit_data['issues']) && is_array($audit_data['issues'])) {
            foreach ($audit_data['issues'] as $issue) {
                $issues[] = (string) $issue;
            }
        }

        $retry_context = "The audit says the draft is incomplete but returned no corrections. Issues: " . implode(' | ', $issues) . ". Return complete section replacements to fix every issue.";
    }

    $issues = array();
    if (!empty($last_audit_data['issues']) && is_array($last_audit_data['issues'])) {
        foreach ($last_audit_data['issues'] as $issue) {
            $issues[] = (string) $issue;
        }
    }

    $message = 'Il controllo finale OpenAI non ha confermato la coerenza completa della bozza.';
    if (!empty($issues)) {
        $message .= ' Problemi: ' . implode(' | ', $issues);
    }

    return new WP_Error('final_audit_failed', $message);
}

/**
 * Chiama OpenAI usando la chiave della struttura per generare una bozza completa delle INSTRUCTIONS.
 * OpenAI lavora come editor intelligente per sezioni: individua tutte le sezioni coinvolte,
 * restituisce solo quelle sezioni riscritte e il plugin ricostruisce il prompt completo finale.
 */
/**
 * Costruisce un prompt più semplice e robusto: OpenAI deve restituire direttamente
 * il blocco INSTRUCTIONS completo aggiornato, non una patch parziale.
 *
 * Questa strategia è più efficace quando la richiesta contiene molte modifiche insieme
 * e richiede propagazione semantica: contatti, password, spelling, regole, servizi,
 * esempi, sezioni collegate e raccomandazioni.
 */
function cube_manager_build_full_rewrite_prompt($request, $current_instructions = '') {
    $structure_name = isset($request->structure_name) ? (string) $request->structure_name : '';
    $city = isset($request->city) ? (string) $request->city : '';
    $uploaded_text = isset($request->uploaded_text) ? (string) $request->uploaded_text : '';
    $current_instructions = trim((string) $current_instructions);
    $sections_index = cube_manager_build_sections_index_for_ai($current_instructions);

    $prompt  = "You are a senior hospitality prompt editor and consistency auditor.\n";
    $prompt .= "You edit the full INSTRUCTIONS block of a CUBE voice assistant installed inside a hospitality structure.\n";
    $prompt .= "This is a production task: accuracy and consistency are more important than brevity.\n\n";

    $prompt .= "STRUCTURE CONTEXT:\n";
    $prompt .= "Structure name: " . $structure_name . "\n";
    $prompt .= "City: " . $city . "\n\n";

    $prompt .= "SECTION INDEX THAT MUST BE PRESERVED:\n";
    $prompt .= $sections_index . "\n\n";

    $prompt .= "CURRENT COMPLETE INSTRUCTIONS — SOURCE OF TRUTH TO EDIT:\n";
    $prompt .= $current_instructions . "\n\n";

    $prompt .= "CUSTOMER UPDATE REQUEST:\n";
    $prompt .= $uploaded_text . "\n\n";

    $prompt .= "YOUR TASK:\n";
    $prompt .= "Return the COMPLETE updated INSTRUCTIONS block, from the first section to the last section.\n";
    $prompt .= "Do not return a patch. Do not return only changed sections. Do not summarize.\n";
    $prompt .= "Keep the complete numbered structure and all unrelated content.\n";
    $prompt .= "Apply every customer-requested change everywhere it is directly or indirectly relevant.\n\n";

    $prompt .= "CRITICAL SEMANTIC PROPAGATION RULES:\n";
    $prompt .= "- Treat the customer's request as a set of facts to update across the whole prompt.\n";
    $prompt .= "- For every changed fact, find all direct mentions and all derived mentions.\n";
    $prompt .= "- Derived mentions include examples, translations, recommended answers, spelling, pronunciation, punctuation notes, final-character warnings, anti-error rules, summaries, and routing instructions.\n";
    $prompt .= "- If a Wi-Fi password changes, update the password itself, all example answers, all repetition/spelling instructions, all Italian/English wording, all punctuation notes, and every sentence that depends on the old password.\n";
    $prompt .= "- Recompute spelling character by character from the new password. Never keep spelling from the old password.\n";
    $prompt .= "- If the new password ends with '$', do not keep any instruction about an exclamation mark. Use dollar sign wording instead.\n";
    $prompt .= "- If a phone number changes, update every contact line, WhatsApp line, assistance sentence, routing sentence, and all sections that tell guests to contact that person for that topic.\n";
    $prompt .= "- If the customer adds a new rule or paid service, place it in the most relevant operational section and also update any problem-handling/missing-information/rules sections if guests may ask about it.\n";
    $prompt .= "- If a pool rule is added, create or update a suitable amenities/facilities/rules section without inventing opening hours, location details, or availability not provided.\n";
    $prompt .= "- If an internal cleaning code word changes, update the entire internal code word section: heading, command word, examples, anti-error rule, meaning-explanation exception, and recommended internal command.\n";
    $prompt .= "- If multiple changes are requested in one message, apply ALL of them. Do not ignore secondary changes.\n\n";

    $prompt .= "PRESERVATION RULES:\n";
    $prompt .= "- Preserve all sections and numbering unless the customer explicitly asks to remove or rename sections.\n";
    $prompt .= "- Preserve identity, tone, language policy, safety rules, operational limits, emergency rules, and anti-hallucination rules unless directly affected.\n";
    $prompt .= "- Do not shorten the instructions.\n";
    $prompt .= "- Do not remove useful existing information.\n";
    $prompt .= "- Do not invent facts, prices, opening hours, addresses, availability, contacts, websites, or services.\n";
    $prompt .= "- If a new fact conflicts with an old fact, replace the old fact everywhere it matters.\n\n";

    $prompt .= "FINAL QA BEFORE OUTPUT:\n";
    $prompt .= "Before answering, check that every requested change is applied:\n";
    $prompt .= "1. changed phone numbers are updated in every relevant section;\n";
    $prompt .= "2. changed Wi-Fi passwords are updated in password, examples, spelling, translations and punctuation notes;\n";
    $prompt .= "3. new rules/services are inserted into all relevant operational sections;\n";
    $prompt .= "4. internal code word changes are applied throughout the entire internal code word section;\n";
    $prompt .= "5. unrelated sections remain present and coherent.\n\n";

    $prompt .= "OUTPUT FORMAT:\n";
    $prompt .= "Return ONLY valid JSON, no Markdown and no code fences, in this exact shape:\n";
    $prompt .= "{\n";
    $prompt .= "  \"updated_instructions\": \"FULL COMPLETE UPDATED INSTRUCTIONS TEXT HERE\",\n";
    $prompt .= "  \"change_summary\": [\"short summary of each applied change\"]\n";
    $prompt .= "}\n";

    return $prompt;
}

/**
 * Decodifica la risposta JSON del full rewrite.
 */
function cube_manager_decode_full_rewrite_text($text) {
    $data = cube_manager_decode_json_patch_text($text);

    if (!is_array($data)) {
        return new WP_Error('openai_invalid_full_json', 'OpenAI non ha restituito un JSON valido con updated_instructions.');
    }

    if (empty($data['updated_instructions']) || !is_string($data['updated_instructions'])) {
        return new WP_Error('openai_missing_updated_instructions', 'OpenAI non ha restituito il campo updated_instructions.');
    }

    return trim((string) $data['updated_instructions']);
}

/**
 * Validazione leggera ma utile del prompt completo generato.
 * Non deve bloccare per falsi positivi semantici, ma deve bloccare output tronchi o incompleti.
 */
function cube_manager_validate_full_rewrite_instructions($original_instructions, $updated_instructions) {
    $original_instructions = trim((string) $original_instructions);
    $updated_instructions = trim((string) $updated_instructions);

    if ($updated_instructions === '') {
        return new WP_Error('empty_full_rewrite', 'La bozza generata è vuota.');
    }

    $original_sections = cube_manager_extract_instruction_sections($original_instructions);
    $updated_sections = cube_manager_extract_instruction_sections($updated_instructions);

    if (count($updated_sections) < max(1, count($original_sections) - 1)) {
        return new WP_Error('full_rewrite_missing_sections', 'La bozza generata sembra incompleta: mancano troppe sezioni.');
    }

    foreach ($original_sections as $number => $section) {
        if (!isset($updated_sections[$number])) {
            return new WP_Error('full_rewrite_missing_section', 'La bozza generata non contiene la sezione ' . $number . '.');
        }
    }

    $original_len = mb_strlen($original_instructions, 'UTF-8');
    $updated_len = mb_strlen($updated_instructions, 'UTF-8');

    if ($original_len > 0 && $updated_len < ($original_len * 0.75)) {
        return new WP_Error('full_rewrite_too_short', 'La bozza generata è troppo corta rispetto alle istruzioni originali.');
    }

    return true;
}

/**
 * Chiama OpenAI usando la chiave della struttura per generare una bozza completa delle INSTRUCTIONS.
 * Strategia 1.5.1: più semplice e robusta.
 * OpenAI restituisce direttamente le istruzioni complete aggiornate, usando GPT-5.5.
 */
function cube_manager_call_openai_for_instructions($api_key, $request, $previous_instructions = '') {
    $previous_instructions = trim((string) $previous_instructions);

    if ($previous_instructions === '') {
        return new WP_Error('missing_source_instructions', 'Mancano le istruzioni sorgente complete da modificare.');
    }

    $system_content = 'You are a meticulous senior prompt editor and QA auditor. You must update complete hospitality voice-assistant instructions according to the customer request. You must apply every requested change everywhere it is directly or indirectly relevant. You must preserve the complete structure and return only valid JSON with updated_instructions.';

    $prompt = cube_manager_build_full_rewrite_prompt($request, $previous_instructions);
    $text = cube_manager_openai_responses_text($api_key, $prompt, $system_content);

    if (is_wp_error($text)) {
        return $text;
    }

    $updated = cube_manager_decode_full_rewrite_text($text);

    if (is_wp_error($updated)) {
        return $updated;
    }

    $validation = cube_manager_validate_full_rewrite_instructions($previous_instructions, $updated);

    if (is_wp_error($validation)) {
        return $validation;
    }

    // Fallback deterministico solo per parola chiave interna: se il cliente ha chiesto una nuova parola
    // e il full rewrite non l'ha inclusa, correggiamo la sezione dedicata invece di perdere la modifica.
    $requested_internal_word = cube_manager_extract_internal_code_word_from_request(
        isset($request->uploaded_text) ? (string) $request->uploaded_text : ''
    );

    if ($requested_internal_word !== '' && !cube_manager_text_contains_normalized($updated, $requested_internal_word)) {
        $fallback_result = cube_manager_try_internal_code_word_fallback($request, $updated);

        if (!is_wp_error($fallback_result) && !empty($fallback_result['patched_instructions'])) {
            $updated = (string) $fallback_result['patched_instructions'];
        }
    }

    $triple_quotes = chr(34) . chr(34) . chr(34);
    $updated = str_replace($triple_quotes, '\"\"\"', $updated);

    return trim($updated);
}

/**
 * Normalizza codice dispositivo.
 */
function cube_manager_normalize_device_code($device_code) {
    $device_code = strtoupper($device_code);
    $device_code = preg_replace('/[^A-Z0-9\-_]/', '', $device_code);
    return $device_code;
}

/**
 * Genera token dispositivo.
 */
function cube_manager_generate_device_secret() {
    return wp_generate_password(64, false, false);
}

/**
 * Chiave di cifratura locale per le API key salvate nel database.
 * Usiamo le salt key di WordPress, così la chiave non viene salvata in chiaro.
 */
function cube_manager_get_encryption_key() {
    $material = '';

    if (defined('AUTH_KEY')) {
        $material .= AUTH_KEY;
    }

    if (defined('SECURE_AUTH_KEY')) {
        $material .= SECURE_AUTH_KEY;
    }

    if (defined('LOGGED_IN_KEY')) {
        $material .= LOGGED_IN_KEY;
    }

    if (empty($material)) {
        $material = wp_salt('auth');
    }

    return hash('sha256', $material, true);
}

/**
 * Cifra un valore sensibile.
 */
function cube_manager_encrypt_secret($plain_text) {
    if (!function_exists('openssl_encrypt')) {
        return false;
    }

    $plain_text = (string) $plain_text;
    $cipher = 'AES-256-CBC';
    $iv_length = openssl_cipher_iv_length($cipher);

    if ($iv_length === false) {
        return false;
    }

    $iv = random_bytes($iv_length);
    $key = cube_manager_get_encryption_key();

    $encrypted = openssl_encrypt($plain_text, $cipher, $key, OPENSSL_RAW_DATA, $iv);

    if ($encrypted === false) {
        return false;
    }

    return 'v1:' . base64_encode($iv) . ':' . base64_encode($encrypted);
}

/**
 * Decifra un valore sensibile.
 * Ci servirà nella fase successiva, quando chiameremo OpenAI dal backend.
 */
function cube_manager_decrypt_secret($stored_value) {
    if (!function_exists('openssl_decrypt')) {
        return false;
    }

    $stored_value = (string) $stored_value;
    $parts = explode(':', $stored_value);

    if (count($parts) !== 3 || $parts[0] !== 'v1') {
        return false;
    }

    $iv = base64_decode($parts[1], true);
    $encrypted = base64_decode($parts[2], true);

    if ($iv === false || $encrypted === false) {
        return false;
    }

    $key = cube_manager_get_encryption_key();

    return openssl_decrypt($encrypted, 'AES-256-CBC', $key, OPENSSL_RAW_DATA, $iv);
}

/**
 * Recupera il record della chiave OpenAI Dashboard associata alla struttura.
 */
function cube_manager_get_structure_openai_key_record($structure_id) {
    global $wpdb;

    $keys_table = $wpdb->prefix . 'cube_customer_keys';

    return $wpdb->get_row(
        $wpdb->prepare(
            "SELECT * FROM $keys_table
             WHERE structure_id = %d
             AND provider = %s
             AND key_purpose = %s
             LIMIT 1",
            (int) $structure_id,
            'openai',
            'instructions'
        )
    );
}

/**
 * Controlla se una struttura ha una chiave OpenAI Dashboard attiva.
 */
function cube_manager_structure_has_openai_key($structure_id) {
    $record = cube_manager_get_structure_openai_key_record($structure_id);

    return (
        $record &&
        $record->key_status === 'active' &&
        !empty($record->encrypted_api_key)
    );
}

/**
 * Salvataggio API key OpenAI Dashboard da area clienti/admin.
 */
function cube_manager_handle_save_openai_key() {
    if (!is_user_logged_in()) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=login_required'));
        exit;
    }

    $user = wp_get_current_user();

    if (
        !in_array('cube_customer', (array) $user->roles, true) &&
        !current_user_can('cube_manage_all')
    ) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=not_allowed'));
        exit;
    }

    $structure_id = isset($_POST['structure_id']) ? absint($_POST['structure_id']) : 0;

    if ($structure_id <= 0 || !cube_manager_user_can_access_structure((int) $user->ID, $structure_id)) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=invalid_structure'));
        exit;
    }

    if (
        !isset($_POST['cube_openai_key_nonce']) ||
        !wp_verify_nonce(
            sanitize_text_field(wp_unslash($_POST['cube_openai_key_nonce'])),
            'cube_save_openai_key_' . $structure_id
        )
    ) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=invalid_request'));
        exit;
    }

    $api_key = isset($_POST['openai_api_key'])
        ? trim(sanitize_text_field(wp_unslash($_POST['openai_api_key'])))
        : '';

    if (empty($api_key)) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=api_key_empty'));
        exit;
    }

    if (substr($api_key, 0, 3) !== 'sk-') {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=api_key_invalid'));
        exit;
    }

    $encrypted = cube_manager_encrypt_secret($api_key);

    if ($encrypted === false) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=api_key_error'));
        exit;
    }

    $structure = cube_manager_get_structure($structure_id);

    if (!$structure) {
        wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=invalid_structure'));
        exit;
    }

    global $wpdb;

    $keys_table = $wpdb->prefix . 'cube_customer_keys';
    $now = current_time('mysql');

    $existing = cube_manager_get_structure_openai_key_record($structure_id);

    $data = array(
        'user_id' => (int) $structure->user_id,
        'structure_id' => (int) $structure_id,
        'provider' => 'openai',
        'key_purpose' => 'instructions',
        'encrypted_api_key' => $encrypted,
        'key_status' => 'active',
        'updated_at' => $now,
    );

    $formats = array('%d', '%d', '%s', '%s', '%s', '%s', '%s');

    if ($existing) {
        $result = $wpdb->update(
            $keys_table,
            $data,
            array('id' => (int) $existing->id),
            $formats,
            array('%d')
        );
    } else {
        $data['created_at'] = $now;
        $formats[] = '%s';

        $result = $wpdb->insert($keys_table, $data, $formats);
    }

    $message = ($result !== false) ? 'api_key_saved' : 'api_key_error';

    wp_safe_redirect(home_url('/area-clienti/?cube_customer_message=' . $message));
    exit;
}
add_action('admin_post_cube_manager_save_openai_key', 'cube_manager_handle_save_openai_key');

