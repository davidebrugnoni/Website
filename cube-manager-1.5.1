function cube_manager_handle_save_device() {
    cube_manager_require_admin_permission();

    if (
        !isset($_POST['cube_device_nonce']) ||
        !wp_verify_nonce(
            sanitize_text_field(wp_unslash($_POST['cube_device_nonce'])),
            'cube_save_device'
        )
    ) {
        wp_safe_redirect(cube_manager_devices_url(array('cube_message' => 'invalid_request')));
        exit;
    }

    global $wpdb;

    $devices_table = $wpdb->prefix . 'cube_devices';

    $device_id = isset($_POST['device_id']) ? absint($_POST['device_id']) : 0;
    $structure_id = isset($_POST['structure_id']) ? absint($_POST['structure_id']) : 0;

    $device_code = isset($_POST['device_code'])
        ? sanitize_text_field(wp_unslash($_POST['device_code']))
        : '';

    $device_code = cube_manager_normalize_device_code($device_code);

    $device_name = isset($_POST['device_name'])
        ? sanitize_text_field(wp_unslash($_POST['device_name']))
        : '';

    $status = isset($_POST['status'])
        ? sanitize_text_field(wp_unslash($_POST['status']))
        : 'active';

    $allowed_statuses = array('active', 'inactive');

    if (!in_array($status, $allowed_statuses, true)) {
        $status = 'active';
    }

    if ($structure_id <= 0 || empty($device_code)) {
        wp_safe_redirect(cube_manager_devices_url(array('cube_message' => 'missing_fields')));
        exit;
    }

    if (cube_manager_device_code_exists($device_code, $device_id)) {
        wp_safe_redirect(cube_manager_devices_url(array('cube_message' => 'device_duplicate')));
        exit;
    }

    $now = current_time('mysql');

    $data = array(
        'structure_id' => $structure_id,
        'device_code'  => $device_code,
        'device_name'  => $device_name,
        'status'       => $status,
        'updated_at'   => $now,
    );

    $formats = array(
        '%d',
        '%s',
        '%s',
        '%s',
        '%s',
    );

    if ($device_id > 0) {
        $result = $wpdb->update(
            $devices_table,
            $data,
            array('id' => $device_id),
            $formats,
            array('%d')
        );

        $message = ($result !== false) ? 'device_updated' : 'device_error';
    } else {
        $plain_secret = cube_manager_generate_device_secret();

        $data['device_secret_hash'] = wp_hash_password($plain_secret);
        $data['created_at'] = $now;

        $formats[] = '%s';
        $formats[] = '%s';

        $result = $wpdb->insert(
            $devices_table,
            $data,
            $formats
        );

        if ($result !== false) {
            set_transient(
                'cube_new_device_secret_' . get_current_user_id(),
                array(
                    'device_code' => $device_code,
                    'device_secret' => $plain_secret,
                ),
                10 * MINUTE_IN_SECONDS
            );

            $message = 'device_created';
        } else {
            $message = 'device_error';
        }
    }

    wp_safe_redirect(cube_manager_devices_url(array('cube_message' => $message)));
    exit;
