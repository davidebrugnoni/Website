/**
 * Impedisce ai clienti CUBE di accedere al backend WordPress.
 */
function cube_manager_block_customer_wp_admin_access() {
    global $pagenow;

    if ($pagenow === 'admin-post.php') {
        return;
    }

    if (
        is_admin() &&
        is_user_logged_in() &&
        !defined('DOING_AJAX')
    ) {
        $user = wp_get_current_user();

        if (
            in_array('cube_customer', (array) $user->roles, true) &&
            !current_user_can('cube_manage_all')
        ) {
            wp_safe_redirect(home_url('/area-clienti/'));
            exit;
        }
    }
}
add_action('admin_init', 'cube_manager_block_customer_wp_admin_access');

/**
 * Nasconde la barra admin WordPress ai clienti CUBE.
 */
function cube_manager_hide_admin_bar_for_customers($show_admin_bar) {
    if (is_user_logged_in()) {
        $user = wp_get_current_user();

        if (
            in_array('cube_customer', (array) $user->roles, true) &&
            !current_user_can('cube_manage_all')
        ) {
            return false;
        }
    }

    return $show_admin_bar;
}
add_filter('show_admin_bar', 'cube_manager_hide_admin_bar_for_customers');

/**
 * In caso di login fallito, rimanda l'utente alla pagina area clienti.
 */
function cube_manager_login_failed_redirect($username = '') {
    wp_safe_redirect(home_url('/area-clienti/?login=failed'));
    exit;
}
add_action('wp_login_failed', 'cube_manager_login_failed_redirect');

/**
 * Se username o password sono vuoti, rimanda alla pagina area clienti.
 */
function cube_manager_empty_login_fields_redirect($user, $username, $password) {
    if (
        isset($_POST['wp-submit']) &&
        (empty($username) || empty($password))
    ) {
        wp_safe_redirect(home_url('/area-clienti/?login=failed'));
        exit;
    }

    return $user;
}
add_filter('authenticate', 'cube_manager_empty_login_fields_redirect', 30, 3);

/**
 * Dopo logout, rimanda alla pagina area clienti.
 */
function cube_manager_logout_redirect($redirect_to, $requested_redirect_to, $user) {
    return home_url('/area-clienti/?loggedout=true');
}
add_filter('logout_redirect', 'cube_manager_logout_redirect', 10, 3);

