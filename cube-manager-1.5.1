/**
 * Controlla se un device_code esiste già.
 */
function cube_manager_device_code_exists($device_code, $exclude_device_id = 0) {
    global $wpdb;

    $devices_table = $wpdb->prefix . 'cube_devices';

    if ($exclude_device_id > 0) {
        $found = $wpdb->get_var(
            $wpdb->prepare(
                "SELECT id FROM $devices_table WHERE device_code = %s AND id != %d LIMIT 1",
                $device_code,
                $exclude_device_id
            )
        );
    } else {
        $found = $wpdb->get_var(
            $wpdb->prepare(
                "SELECT id FROM $devices_table WHERE device_code = %s LIMIT 1",
                $device_code
            )
        );
    }

    return !empty($found);
}

/**
 * Controlla se l'utente può accedere alla struttura.
 */
function cube_manager_user_can_access_structure($user_id, $structure_id) {
    if (current_user_can('cube_manage_all')) {
        return true;
    }

    $structure = cube_manager_get_structure((int) $structure_id);

    if (!$structure) {
        return false;
    }

    return (int) $structure->user_id === (int) $user_id;
}

/**
 * Recupera prossimo numero versione/richiesta per struttura.
 */
function cube_manager_get_next_define_version_number($structure_id) {
    global $wpdb;

    $versions_table = $wpdb->prefix . 'cube_define_versions';

    $max_version = (int) $wpdb->get_var(
        $wpdb->prepare(
            "SELECT MAX(version_number) FROM $versions_table WHERE structure_id = %d",
            (int) $structure_id
        )
    );

    return $max_version + 1;
}

