/**
 * Messaggi admin.
 */
function cube_manager_admin_notice_from_query() {
    if (!isset($_GET['cube_message'])) {
        return;
    }

    $message = sanitize_text_field(wp_unslash($_GET['cube_message']));

    $messages = array(
        'structure_created' => array('success', 'Struttura creata correttamente.'),
        'structure_updated' => array('success', 'Struttura aggiornata correttamente.'),
        'structure_deleted' => array('success', 'Struttura eliminata correttamente.'),
        'structure_error'   => array('error', 'Errore durante il salvataggio della struttura.'),

        'device_created'    => array('success', 'Dispositivo creato correttamente. Copia subito il token mostrato nella pagina dispositivi.'),
        'device_updated'    => array('success', 'Dispositivo aggiornato correttamente.'),
        'device_deleted'    => array('success', 'Dispositivo eliminato correttamente.'),
        'device_error'      => array('error', 'Errore durante il salvataggio del dispositivo.'),
        'device_duplicate'  => array('error', 'Esiste già un dispositivo con questo codice.'),

        'request_approved'  => array('success', 'Richiesta approvata correttamente.'),
        'request_rejected'  => array('success', 'Richiesta rifiutata correttamente.'),
        'request_error'     => array('error', 'Errore durante la gestione della richiesta.'),

        'api_key_saved'    => array('success', 'Chiave OpenAI salvata correttamente.'),
        'api_key_deleted'  => array('success', 'Chiave OpenAI eliminata correttamente.'),
        'api_key_error'    => array('error', 'Errore durante il salvataggio della chiave OpenAI.'),

        'instructions_generated' => array('success', 'Bozza INSTRUCTIONS generata correttamente con OpenAI.'),
        'instructions_saved'     => array('success', 'Bozza INSTRUCTIONS salvata correttamente.'),
        'define_published'       => array('success', 'define.py pubblicato correttamente per la struttura. I dispositivi lo scaricheranno al prossimo avvio.'),
        'define_error'           => array('error', 'Errore durante la generazione o pubblicazione del define.py.'),
        'instructions_missing'   => array('error', 'Prima di pubblicare devi generare o salvare una bozza INSTRUCTIONS.'),
        'ai_key_missing'         => array('error', 'Per questa struttura manca la chiave OpenAI Dashboard.'),
        'ai_key_decrypt_error'   => array('error', 'Impossibile leggere la chiave OpenAI salvata. Inseriscila di nuovo dall’area clienti.'),
        'ai_request_error'       => array('error', 'Errore durante la chiamata a OpenAI. Controlla chiave, credito e permessi.'),
        'ai_empty_output'        => array('error', 'OpenAI non ha restituito una bozza valida.'),

        'missing_fields'    => array('error', 'Compila tutti i campi obbligatori.'),
        'invalid_request'   => array('error', 'Richiesta non valida.'),
    );

    if (!isset($messages[$message])) {
        return;
    }

    $type = $messages[$message][0];
    $text = $messages[$message][1];

    if ($message === 'ai_request_error') {
        $last_ai_error = get_transient('cube_last_ai_error_' . get_current_user_id());
        if (!empty($last_ai_error)) {
            $text .= ' Dettaglio tecnico: ' . (string) $last_ai_error;
            delete_transient('cube_last_ai_error_' . get_current_user_id());
        }
    }

    echo '<div class="notice notice-' . esc_attr($type) . ' is-dismissible"><p>' . esc_html($text) . '</p></div>';
}
add_action('admin_notices', 'cube_manager_admin_notice_from_query');

